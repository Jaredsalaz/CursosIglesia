@page "/cursos"
@inject CoursesViewModel ViewModel

<PageTitle>Catálogo de Cursos - Cursos Católicos</PageTitle>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1><i class="bi bi-mortarboard me-2"></i>Catálogo de Cursos</h1>
        <p>Descubre nuestra oferta formativa y elige el curso que transformará tu fe</p>
    </div>
</section>

@if (ViewModel.IsLoading)
{
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando cursos...</p>
    </div>
}
else
{
    <section class="section">
        <div class="container">
            <!-- Filter Bar -->
            <div class="filter-bar">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            <i class="bi bi-search me-1"></i>Buscar
                        </label>
                        <input type="text" class="form-control" placeholder="Buscar cursos..."
                               @bind="ViewModel.SearchQuery" @bind:event="oninput" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">
                            <i class="bi bi-tag me-1"></i>Categoría
                        </label>
                        <select class="form-select" @bind="ViewModel.SelectedCategoryId">
                            <option value="0">Todas las categorías</option>
                            @foreach (var cat in ViewModel.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">
                            <i class="bi bi-bar-chart me-1"></i>Nivel
                        </label>
                        <select class="form-select" @bind="ViewModel.SelectedDifficulty">
                            <option value="">Todos los niveles</option>
                            <option value="@DifficultyLevel.Principiante">Principiante</option>
                            <option value="@DifficultyLevel.Intermedio">Intermedio</option>
                            <option value="@DifficultyLevel.Avanzado">Avanzado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">
                            <i class="bi bi-sort-down me-1"></i>Ordenar
                        </label>
                        <select class="form-select" @bind="ViewModel.SortBy">
                            <option value="popular">Más populares</option>
                            <option value="recent">Más recientes</option>
                            <option value="rating">Mejor valorados</option>
                            <option value="name">Nombre A-Z</option>
                            <option value="price-low">Precio: menor</option>
                            <option value="price-high">Precio: mayor</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-outline-secondary w-100" @onclick="ViewModel.ClearFilters"
                                title="Limpiar filtros">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Results count -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="text-muted mb-0">
                    <strong>@ViewModel.FilteredCourses.Count</strong> curso(s) encontrado(s)
                </p>
            </div>

            <!-- Course Grid -->
            @if (ViewModel.FilteredCourses.Any())
            {
                <div class="row g-4">
                    @foreach (var course in ViewModel.FilteredCourses)
                    {
                        <div class="col-md-6 col-lg-4">
                            <CourseCard Course="course" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search" style="font-size:3rem; color:var(--color-text-muted)"></i>
                    <h4 class="mt-3">No se encontraron cursos</h4>
                    <p class="text-muted">Intenta ajustar los filtros de búsqueda</p>
                    <button class="btn-catholic" @onclick="ViewModel.ClearFilters">
                        <i class="bi bi-arrow-counterclockwise"></i> Limpiar Filtros
                    </button>
                </div>
            }
        </div>
    </section>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }
}
