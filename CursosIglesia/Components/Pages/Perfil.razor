@page "/perfil"
@rendermode InteractiveServer
@inject UserProfileViewModel ViewModel

<PageTitle>Mi Perfil - Cursos Católicos</PageTitle>

<section class="page-header">
    <div class="container">
        <h1><i class="bi bi-person-gear me-2"></i>Mi Perfil</h1>
        <p>Gestiona tu información personal y preferencias</p>
    </div>
</section>

@if (ViewModel.IsLoading)
{
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando perfil...</p>
    </div>
}
else
{
    <section class="section">
        <div class="container">
            <!-- Profile Header Card -->
            <div class="profile-header-card">
                <div class="profile-avatar-section">
                    <img src="@ViewModel.Profile.AvatarUrl" alt="@ViewModel.Profile.FullName" class="profile-avatar-large" />
                    <div class="profile-header-info">
                        <h2>@ViewModel.Profile.FullName</h2>
                        <p class="profile-email">@ViewModel.Profile.Email</p>
                        <div class="profile-header-stats">
                            <span><i class="bi bi-journal-bookmark me-1"></i>@ViewModel.EnrolledCount cursos inscritos</span>
                            <span><i class="bi bi-check-circle me-1"></i>@ViewModel.CompletedCount completados</span>
                            <span><i class="bi bi-calendar me-1"></i>Miembro desde @ViewModel.Profile.JoinedDate.ToString("MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="profile-tabs">
                <button class="profile-tab @(ViewModel.ActiveTab == "personal" ? "active" : "")"
                        @onclick="SwitchToPersonal">
                    <i class="bi bi-person me-1"></i> Datos Personales
                </button>
                <button class="profile-tab @(ViewModel.ActiveTab == "security" ? "active" : "")"
                        @onclick="SwitchToSecurity">
                    <i class="bi bi-shield-lock me-1"></i> Seguridad
                </button>
                <button class="profile-tab @(ViewModel.ActiveTab == "payments" ? "active" : "")"
                        @onclick="SwitchToPayments">
                    <i class="bi bi-credit-card me-1"></i> Pagos
                </button>
                <button class="profile-tab @(ViewModel.ActiveTab == "notifications" ? "active" : "")"
                        @onclick="SwitchToNotifications">
                    <i class="bi bi-bell me-1"></i> Notificaciones
                </button>
            </div>

            <!-- Success/Error Messages -->
            @if (ViewModel.SuccessMessage != null)
            {
                <div class="alert-success-custom">
                    <i class="bi bi-check-circle-fill me-2"></i>@ViewModel.SuccessMessage
                </div>
            }
            @if (ViewModel.ErrorMessage != null)
            {
                <div class="alert-error-custom">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewModel.ErrorMessage
                </div>
            }

            <!-- Tab Content -->
            <div class="profile-tab-content">
                @if (ViewModel.ActiveTab == "personal")
                {
                    <div class="profile-section-card">
                        <h4><i class="bi bi-person-vcard me-2"></i>Información Personal</h4>
                        <div class="profile-form">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="profile-label">Nombre</label>
                                    <input type="text" class="profile-input" @bind="ViewModel.EditFirstName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="profile-label">Apellido</label>
                                    <input type="text" class="profile-input" @bind="ViewModel.EditLastName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="profile-label">Correo Electrónico</label>
                                    <input type="email" class="profile-input" @bind="ViewModel.EditEmail" />
                                </div>
                                <div class="col-md-6">
                                    <label class="profile-label">Teléfono</label>
                                    <input type="tel" class="profile-input" @bind="ViewModel.EditPhone" />
                                </div>
                                <div class="col-12">
                                    <label class="profile-label">Biografía</label>
                                    <textarea class="profile-input profile-textarea" @bind="ViewModel.EditBio" rows="3"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="profile-section-card">
                        <h4><i class="bi bi-geo-alt me-2"></i>Información de Parroquia</h4>
                        <div class="profile-form">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="profile-label">Parroquia</label>
                                    <input type="text" class="profile-input" @bind="ViewModel.EditParish" />
                                </div>
                                <div class="col-md-6">
                                    <label class="profile-label">Ciudad</label>
                                    <input type="text" class="profile-input" @bind="ViewModel.EditCity" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="profile-action-bar">
                        <button class="btn-catholic" @onclick="SaveProfile">
                            <i class="bi bi-check-lg me-1"></i> Guardar Cambios
                        </button>
                    </div>
                }

                @if (ViewModel.ActiveTab == "security")
                {
                    <div class="profile-section-card">
                        <h4><i class="bi bi-key me-2"></i>Cambiar Contraseña</h4>
                        <div class="profile-form">
                            <div class="row g-3">
                                <div class="col-md-8 col-lg-6">
                                    <label class="profile-label">Contraseña Actual</label>
                                    <input type="password" class="profile-input" @bind="ViewModel.CurrentPassword" />
                                </div>
                                <div class="col-md-8 col-lg-6">
                                    <label class="profile-label">Nueva Contraseña</label>
                                    <input type="password" class="profile-input" @bind="ViewModel.NewPassword" />
                                    <small class="profile-hint">Mínimo 8 caracteres</small>
                                </div>
                                <div class="col-md-8 col-lg-6">
                                    <label class="profile-label">Confirmar Nueva Contraseña</label>
                                    <input type="password" class="profile-input" @bind="ViewModel.ConfirmPassword" />
                                </div>
                            </div>
                        </div>
                        <div class="profile-action-bar">
                            <button class="btn-catholic" @onclick="ChangePassword">
                                <i class="bi bi-shield-check me-1"></i> Actualizar Contraseña
                            </button>
                        </div>
                    </div>

                    <div class="profile-section-card">
                        <h4><i class="bi bi-shield-exclamation me-2"></i>Sesiones Activas</h4>
                        <div class="session-item">
                            <div class="session-info">
                                <i class="bi bi-laptop me-2"></i>
                                <div>
                                    <div class="session-device">Windows · Chrome</div>
                                    <div class="session-detail">Ciudad de México · Activo ahora</div>
                                </div>
                            </div>
                            <span class="session-active-badge">Sesión actual</span>
                        </div>
                    </div>
                }

                @if (ViewModel.ActiveTab == "payments")
                {
                    <div class="profile-section-card">
                        <h4><i class="bi bi-credit-card-2-front me-2"></i>Métodos de Pago</h4>

                        @if (ViewModel.Profile.PaymentMethods.Any())
                        {
                            <div class="payment-methods-list">
                                @foreach (var method in ViewModel.Profile.PaymentMethods)
                                {
                                    <div class="payment-method-card">
                                        <div class="payment-card-icon">
                                            @if (method.Type == "visa")
                                            {
                                                <i class="bi bi-credit-card-2-front"></i>
                                            }
                                            else if (method.Type == "mastercard")
                                            {
                                                <i class="bi bi-credit-card"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-wallet2"></i>
                                            }
                                        </div>
                                        <div class="payment-card-info">
                                            <div class="payment-card-type">
                                                @method.Type.ToUpper() •••• @method.LastFourDigits
                                                @if (method.IsDefault)
                                                {
                                                    <span class="payment-default-badge">Predeterminada</span>
                                                }
                                            </div>
                                            <div class="payment-card-expiry">Expira: @method.ExpiryDate</div>
                                        </div>
                                        <button class="payment-remove-btn" @onclick="() => RemovePayment(method.Id)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="payment-empty">
                                <i class="bi bi-credit-card"></i>
                                <p>No tienes métodos de pago registrados</p>
                            </div>
                        }

                        <button class="btn-add-payment">
                            <i class="bi bi-plus-circle me-1"></i> Agregar Método de Pago
                        </button>
                    </div>

                    <div class="profile-section-card">
                        <h4><i class="bi bi-receipt me-2"></i>Historial de Compras</h4>
                        <div class="payment-empty">
                            <i class="bi bi-receipt-cutoff"></i>
                            <p>No tienes compras registradas</p>
                        </div>
                    </div>
                }

                @if (ViewModel.ActiveTab == "notifications")
                {
                    <div class="profile-section-card">
                        <h4><i class="bi bi-bell me-2"></i>Preferencias de Notificación</h4>
                        <div class="notification-options">
                            <div class="notification-option">
                                <div class="notification-option-info">
                                    <div class="notification-option-title">Notificaciones por Email</div>
                                    <div class="notification-option-desc">Recibe un resumen de actividad en tu correo</div>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" @bind="ViewModel.Profile.Notifications.EmailNotifications" />
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                            <div class="notification-option">
                                <div class="notification-option-info">
                                    <div class="notification-option-title">Actualizaciones de Cursos</div>
                                    <div class="notification-option-desc">Notificaciones cuando se actualice un curso en el que estás inscrito</div>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" @bind="ViewModel.Profile.Notifications.CourseUpdates" />
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                            <div class="notification-option">
                                <div class="notification-option-info">
                                    <div class="notification-option-title">Alertas de Nuevos Cursos</div>
                                    <div class="notification-option-desc">Entérate de los nuevos cursos disponibles</div>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" @bind="ViewModel.Profile.Notifications.NewCourseAlerts" />
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                            <div class="notification-option">
                                <div class="notification-option-info">
                                    <div class="notification-option-title">Correos Promocionales</div>
                                    <div class="notification-option-desc">Ofertas y descuentos especiales</div>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" @bind="ViewModel.Profile.Notifications.PromotionalEmails" />
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>
                        <div class="profile-action-bar">
                            <button class="btn-catholic" @onclick="SaveNotifications">
                                <i class="bi bi-check-lg me-1"></i> Guardar Preferencias
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }

    private void SwitchToPersonal() => ViewModel.SwitchTab("personal");
    private void SwitchToSecurity() => ViewModel.SwitchTab("security");
    private void SwitchToPayments() => ViewModel.SwitchTab("payments");
    private void SwitchToNotifications() => ViewModel.SwitchTab("notifications");

    private async Task SaveProfile()
    {
        await ViewModel.SaveProfileAsync();
    }

    private async Task ChangePassword()
    {
        await ViewModel.ChangePasswordAsync();
    }

    private async Task RemovePayment(int id)
    {
        await ViewModel.RemovePaymentMethodAsync(id);
    }

    private async Task SaveNotifications()
    {
        await ViewModel.SaveNotificationsAsync();
    }
}
