@page "/"
@inject HomeViewModel ViewModel

<PageTitle>Cursos Católicos - Formación en la Fe</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="loading-container" style="min-height:400px">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando contenido...</p>
    </div>
}
else
{
    <!-- HERO SECTION -->
    <section class="hero-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 hero-content">
                    <h1>Formación Católica<br /><span>al Alcance de Todos</span></h1>
                    <p>Profundiza en tu fe con cursos impartidos por sacerdotes, religiosos y teólogos. Desde el Catecismo hasta la Sagrada Escritura, crece en tu conocimiento de la Iglesia.</p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="/cursos" class="btn-catholic">
                            <i class="bi bi-play-circle"></i> Explorar Cursos
                        </a>
                        <a href="/nosotros" class="btn-catholic-outline">
                            <i class="bi bi-info-circle"></i> Conoce Más
                        </a>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <span class="stat-number">@ViewModel.TotalCourses+</span>
                            <span class="stat-label">Cursos</span>
                        </div>
                        <div class="hero-stat">
                            <span class="stat-number">@(ViewModel.TotalStudents.ToString("N0"))+</span>
                            <span class="stat-label">Estudiantes</span>
                        </div>
                        <div class="hero-stat">
                            <span class="stat-number">@ViewModel.Categories.Count</span>
                            <span class="stat-label">Categorías</span>
                        </div>
                        <div class="hero-stat">
                            <span class="stat-number">4.8</span>
                            <span class="stat-label">Valoración</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CATEGORIES SECTION -->
    <section class="section">
        <div class="container">
            <div class="text-center">
                <h2 class="section-title">Explora por <span>Categoría</span></h2>
                <div class="decorative-divider">
                    <i class="bi bi-cross"></i>
                </div>
                <p class="section-subtitle">Encuentra el curso perfecto según tu área de interés</p>
            </div>
            <div class="row g-3">
                @foreach (var cat in ViewModel.Categories.Take(8))
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/cursos" style="text-decoration:none">
                            <div class="category-card">
                                <div class="category-icon">
                                    <i class="bi @cat.Icon"></i>
                                </div>
                                <h5>@cat.Name</h5>
                                <p>@cat.CourseCount curso(s)</p>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- FEATURED COURSES -->
    <section class="section section-alt">
        <div class="container">
            <div class="text-center">
                <h2 class="section-title">Cursos <span>Destacados</span></h2>
                <div class="decorative-divider">
                    <i class="bi bi-cross"></i>
                </div>
                <p class="section-subtitle">Los cursos más recomendados por nuestra comunidad</p>
            </div>
            <div class="row g-4">
                @foreach (var course in ViewModel.FeaturedCourses.Take(6))
                {
                    <div class="col-md-6 col-lg-4">
                        <CourseCard Course="course" />
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a href="/cursos" class="btn-gold">
                    Ver Todos los Cursos <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- WHY US SECTION -->
    <section class="section">
        <div class="container">
            <div class="text-center">
                <h2 class="section-title">¿Por Qué <span>Elegirnos?</span></h2>
                <div class="decorative-divider">
                    <i class="bi bi-cross"></i>
                </div>
                <p class="section-subtitle">Formación católica de calidad con respaldo del Magisterio</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3 text-center">
                    <div class="feature-icon-box mx-auto">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5>Fiel al Magisterio</h5>
                    <p class="text-muted small">Todos nuestros cursos están alineados con la enseñanza oficial de la Iglesia Católica.</p>
                </div>
                <div class="col-md-6 col-lg-3 text-center">
                    <div class="feature-icon-box mx-auto">
                        <i class="bi bi-mortarboard"></i>
                    </div>
                    <h5>Instructores Expertos</h5>
                    <p class="text-muted small">Sacerdotes, religiosos y teólogos con amplia experiencia en formación católica.</p>
                </div>
                <div class="col-md-6 col-lg-3 text-center">
                    <div class="feature-icon-box mx-auto">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <h5>A Tu Ritmo</h5>
                    <p class="text-muted small">Estudia cuando quieras, donde quieras. Acceso ilimitado a tu contenido.</p>
                </div>
                <div class="col-md-6 col-lg-3 text-center">
                    <div class="feature-icon-box mx-auto">
                        <i class="bi bi-people"></i>
                    </div>
                    <h5>Comunidad de Fe</h5>
                    <p class="text-muted small">Únete a miles de católicos que profundizan juntos en su fe.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- POPULAR COURSES -->
    <section class="section section-alt">
        <div class="container">
            <div class="text-center">
                <h2 class="section-title">Los Más <span>Populares</span></h2>
                <div class="decorative-divider">
                    <i class="bi bi-cross"></i>
                </div>
                <p class="section-subtitle">Los cursos con más estudiantes inscritos</p>
            </div>
            <div class="row g-4">
                @foreach (var course in ViewModel.PopularCourses.Take(3))
                {
                    <div class="col-md-6 col-lg-4">
                        <CourseCard Course="course" />
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="section section-dark">
        <div class="container">
            <div class="text-center">
                <h2 class="section-title">Lo Que Dicen Nuestros <span>Estudiantes</span></h2>
                <div class="decorative-divider">
                    <i class="bi bi-cross" style="color:var(--color-secondary-light)"></i>
                </div>
                <p class="section-subtitle">Testimonios de quienes han transformado su fe con nuestros cursos</p>
            </div>
            <div class="row g-4">
                @foreach (var testimonial in ViewModel.Testimonials.Take(3))
                {
                    <div class="col-md-4">
                        <div class="testimonial-card">
                            <div class="quote-icon"><i class="bi bi-quote"></i></div>
                            <div class="testimonial-stars">
                                @for (int i = 0; i < testimonial.Rating; i++)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                            </div>
                            <p class="testimonial-text">"@testimonial.Comment"</p>
                            <div class="testimonial-author">
                                <img src="@testimonial.StudentImageUrl" alt="@testimonial.StudentName" />
                                <div>
                                    <div class="author-name">@testimonial.StudentName</div>
                                    <div class="author-course">@testimonial.CourseName</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <div class="container">
            <h2>¿Listo para Profundizar en tu Fe?</h2>
            <p>Únete a nuestra comunidad de más de @(ViewModel.TotalStudents.ToString("N0")) estudiantes católicos</p>
            <a href="/cursos" class="btn-cta">
                <i class="bi bi-rocket-takeoff"></i> Comenzar Ahora
            </a>
        </div>
    </section>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }
}
