@page "/dashboard/maestro/cursos/{CourseId:guid}/lecciones"
@layout CursosIglesia.Components.Layout.DashboardLayout
@inject IMaestroService MaestroService
@inject IAuthService AuthService
@inject IJSRuntime JSRuntime
@using CursosIglesia.Models
@using CursosIglesia.Models.DTOs
@using Microsoft.AspNetCore.Components.Forms

<!-- Actions Bar -->
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    <a href="/dashboard/maestro/cursos" class="dash-btn dash-btn-outline dash-btn-sm">
        <i class="bi bi-arrow-left"></i> Volver a Cursos
    </a>
    <button class="dash-btn dash-btn-primary" @onclick="() => OpenCreateModal()">
        <i class="bi bi-plus-lg"></i> Nueva Lección
    </button>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="dash-alert @alertClass">
        <i class="bi @alertIcon"></i> @alertMessage
    </div>
}

<!-- Lessons List -->
<div class="dash-panel" style="background: transparent; box-shadow: none;">
    <div class="dash-panel-header" style="background: var(--dash-panel-bg); border-radius: 12px; margin-bottom: 20px; box-shadow: var(--dash-shadow);">
        <span class="dash-panel-title"><i class="bi bi-list-check"></i> Módulos del Curso</span>
        <span class="dash-badge dash-badge-gold">@lessons.Count módulos</span>
    </div>

    @if (loading)
    {
        <div class="dash-loading"><div class="dash-spinner"></div></div>
    }
    else if (lessons.Any())
    {
        <div class="lessons-accordion">
            @foreach (var l in lessons.OrderBy(x => x.Order))
            {
                <div class="lesson-card" style="background:var(--dash-panel-bg); border-radius:12px; margin-bottom:15px; box-shadow:var(--dash-shadow); overflow:hidden;">
                    <!-- Lesson Header -->
                    <div class="lesson-header" style="padding:15px 20px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; border-bottom: @(expandedLessons.Contains(l.Id) ? "1px solid var(--dash-border)" : "none")" @onclick="() => ToggleLessonAccordion(l.Id)">
                        <div style="display:flex; align-items:center; gap:15px;">
                            <span class="dash-badge dash-badge-gold" style="font-size:1rem; width:30px; height:30px; display:flex; align-items:center; justify-content:center;">@l.Order</span>
                            <div>
                                <div style="font-weight:600; font-size:1.1rem; color:var(--dash-text);">@l.Title</div>
                                @if (!string.IsNullOrEmpty(l.Description))
                                {
                                    <div style="font-size:0.85rem; color:var(--dash-text-muted);">@l.Description</div>
                                }
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; gap:15px;" @onclick:stopPropagation="true">
                            <span class="dash-badge dash-badge-info">
                                <i class="bi bi-stack"></i> @(l.Topics?.Count ?? 0) Temas
                            </span>
                            <div style="display:flex; gap:5px;">
                                <button class="dash-btn dash-btn-outline dash-btn-sm" @onclick="() => OpenEditModal(l)" title="Editar Módulo">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="dash-btn dash-btn-danger dash-btn-sm" @onclick="() => DeleteLesson(l.Id)" title="Eliminar Módulo">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <button class="dash-btn dash-btn-outline dash-btn-sm" @onclick="() => ToggleLessonAccordion(l.Id)" style="border:none;">
                                    <i class="bi @(expandedLessons.Contains(l.Id) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Topics Body -->
                    @if (expandedLessons.Contains(l.Id))
                    {
                        <div class="lesson-body" style="padding:20px; background: rgba(0,0,0,0.1);">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                                <h5 style="margin:0; font-size:1rem; color:var(--dash-text);"><i class="bi bi-bookmark-star me-2"></i>Contenido del Módulo</h5>
                                <button class="dash-btn dash-btn-primary dash-btn-sm" @onclick="() => OpenTopicCreateModal(l.Id)">
                                    <i class="bi bi-plus-lg"></i> Agregar Tema
                                </button>
                            </div>

                            @if (l.Topics == null || !l.Topics.Any())
                            {
                                <div style="padding:20px; text-align:center; color:var(--dash-text-muted); border: 2px dashed var(--dash-border); border-radius:8px;">
                                    <i class="bi bi-folder-x" style="font-size:2rem; display:block; margin-bottom:10px;"></i>
                                    Este módulo no tiene temas todavía. Apreta "Agregar Tema" para crear contenido.
                                </div>
                            }
                            else
                            {
                                <div class="topics-list" style="display:flex; flex-direction:column; gap:10px;">
                                    @foreach (var t in l.Topics.OrderBy(x => x.Order))
                                    {
                                        <div class="topic-item" style="background:var(--dash-panel-bg); border-left: 3px solid var(--color-primary); padding:10px 15px; border-radius:6px; display:flex; justify-content:space-between; align-items:center;">
                                            <div style="display:flex; align-items:center; gap:15px;">
                                                <i class="bi @GetTopicIcon(t.ContentType)" style="font-size:1.5rem; color:var(--dash-text-muted);"></i>
                                                <div>
                                                    <div style="font-weight:500; color:var(--dash-text);">@t.Title</div>
                                                    <div style="font-size:0.8rem; color:var(--dash-text-muted);">
                                                        <span class="me-3"><i class="bi bi-clock"></i> @t.DurationMinutes min</span>
                                                        <span>@GetTopicTypeName(t.ContentType)</span>
                                                        @if (t.IsFree) { <span class="ms-3 dash-badge dash-badge-success" style="font-size:0.6rem; padding:2px 5px;">GRATIS</span> }
                                                    </div>
                                                </div>
                                            </div>
                                            <div style="display:flex; gap:5px;">
                                                @if (t.ContentType == ContentType.Test)
                                                {
                                                    <a href="/dashboard/maestro/temas/@t.Id/quiz" class="dash-btn dash-btn-outline dash-btn-sm" title="Quiz Builder">
                                                        <i class="bi bi-ui-checks-grid"></i> Quiz
                                                    </a>
                                                }
                                                <button class="dash-btn dash-btn-outline dash-btn-sm" @onclick="() => OpenTopicEditModal(t, l.Id)" title="Editar Tema">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="dash-btn dash-btn-danger dash-btn-sm" @onclick="() => DeleteTopic(t.Id, l.Id)" title="Eliminar Tema">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="dash-empty" style="background:var(--dash-panel-bg); border-radius:12px;">
            <i class="bi bi-list-check"></i>
            <h4>Sin módulos aún</h4>
            <p>Crea tu primer módulo (lección) para estructurar el curso</p>
        </div>
    }
</div>

<!-- LECCION Modal -->
@if (showModal)
{
    <div class="dash-modal-backdrop" @onclick="() => showModal = false">
        <div class="dash-modal" @onclick:stopPropagation="true">
            <div class="dash-modal-header">
                <span class="dash-modal-title">
                    <i class="bi @(isEditing ? "bi-pencil-square" : "bi-plus-circle")" style="color:var(--dash-accent)"></i>
                    @(isEditing ? "Editar Módulo" : "Nuevo Módulo")
                </span>
                <button class="dash-modal-close" @onclick="() => showModal = false"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="dash-modal-body">
                <div class="dash-form-group">
                    <label class="dash-form-label">Título *</label>
                    <input class="dash-form-input" @bind="currentLesson.Title" placeholder="Ej: Unidad 1: Bases del Cristianismo" />
                </div>
                <div class="dash-form-group">
                    <label class="dash-form-label">Descripción</label>
                    <textarea class="dash-form-textarea" @bind="currentLesson.Description" placeholder="Breve introducción de la unidad"></textarea>
                </div>
                <div class="dash-form-group">
                    <label class="dash-form-label">Orden</label>
                    <input class="dash-form-input" type="number" @bind="currentLesson.Order" />
                </div>
            </div>
            <div class="dash-modal-footer">
                <button class="dash-btn dash-btn-outline" @onclick="() => showModal = false">Cancelar</button>
                <button class="dash-btn dash-btn-primary" @onclick="SaveLesson" disabled="@saving">
                    @if (saving) { <span>Guardando...</span> }
                    else { <span><i class="bi bi-check-lg"></i> @(isEditing ? "Actualizar" : "Crear")</span> }
                </button>
            </div>
        </div>
    </div>
}

<!-- TOPIC Modal -->
@if (showTopicModal)
{
    <!-- Using a slightly wider modal for topic creation due to extra fields -->
    <div class="dash-modal-backdrop" style="align-items:flex-start; padding-top:2rem; overflow-y:auto;" @onclick="() => showTopicModal = false">
        <div class="dash-modal" style="width:100%; max-width:800px; margin:auto;" @onclick:stopPropagation="true">
            <div class="dash-modal-header">
                <span class="dash-modal-title">
                    <i class="bi @(isEditing ? "bi-pencil-square" : "bi-journal-plus")" style="color:var(--dash-accent)"></i>
                    @(isEditing ? "Editar Tema" : "Agregar Nuevo Tema")
                </span>
                <button class="dash-modal-close" @onclick="() => showTopicModal = false"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="dash-modal-body">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <div class="dash-form-group">
                            <label class="dash-form-label">Título del Tema *</label>
                            <input class="dash-form-input" @bind="currentTopic.Title" placeholder="Ej: Las raíces de la fe..." />
                        </div>
                        
                        <div class="dash-form-group">
                            <label class="dash-form-label">Tipo de Contenido *</label>
                            <select class="dash-form-input" @bind="currentTopic.ContentType">
                                @foreach (ContentType type in Enum.GetValues(typeof(ContentType)))
                                {
                                    <option value="@type">@GetTopicTypeName(type)</option>
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div>
                        <div class="dash-form-group">
                            <label class="dash-form-label">Duración (minutos)</label>
                            <input class="dash-form-input" type="number" @bind="currentTopic.DurationMinutes" />
                        </div>
                        
                        <div class="dash-form-group">
                            <label class="dash-form-label">Orden en el módulo</label>
                            <input class="dash-form-input" type="number" @bind="currentTopic.Order" />
                        </div>
                        
                        <div class="dash-form-group" style="margin-top:25px;">
                            <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                                <input type="checkbox" @bind="currentTopic.IsFree" style="width:20px; height:20px;" />
                                <span style="font-weight:600; color:var(--dash-text)">Tema Gratis (Preview)</span>
                            </label>
                        </div>
                    </div>
                </div>

                <hr style="border-color:var(--dash-border); margin:15px 0;"/>

                <div class="dash-form-group">
                    <label class="dash-form-label">Breve Descripción (Opcional)</label>
                    <textarea class="dash-form-textarea" rows="2" @bind="currentTopic.Description" placeholder="De qué trata este tema..."></textarea>
                </div>

                <!-- Dynamic Content Area based on Type -->
                @if (currentTopic.ContentType == ContentType.VideoExterno || currentTopic.ContentType == ContentType.ClaseVirtual || currentTopic.ContentType == ContentType.Archivo)
                {
                    <div class="dash-form-group p-3 mb-2" style="background:rgba(var(--color-primary-rgb), 0.1); border-radius:8px; border:1px solid rgba(var(--color-primary-rgb), 0.3);">
                        <label class="dash-form-label">
                            <i class="bi bi-link-45deg"></i> 
                            @(currentTopic.ContentType == ContentType.VideoExterno ? "URL del Video (YouTube/Vimeo)" : 
                              currentTopic.ContentType == ContentType.ClaseVirtual ? "Enlace de Zoom/Meet" : "URL del Archivo")
                        </label>
                        <input class="dash-form-input" @bind="currentTopic.ContentUrl" placeholder="https://..." />
                    </div>
                }

                @if (currentTopic.ContentType == ContentType.Lectura || currentTopic.ContentType == ContentType.VideoExterno || currentTopic.ContentType == ContentType.VideoSubido)
                {
                     <div class="dash-form-group">
                        <label class="dash-form-label"><i class="bi bi-textarea-t"></i> Contenido principal (Estilo Word / Enriquecido)</label>
                        <div id="quill-editor" style="height: 350px; background: white; color: #333; border-radius: 0 0 8px 8px; font-family: 'Inter', sans-serif;">
                        </div>
                    </div>
                }
                else if (currentTopic.ContentType == ContentType.Test)
                {
                    <div class="dash-form-group">
                        <div class="dash-alert dash-alert-info" style="border-radius:12px; margin-top:10px; display:flex; align-items:flex-start; gap:15px; border-left:4px solid var(--dash-accent); background:rgba(var(--color-primary-rgb), 0.05);">
                            <i class="bi bi-ui-checks-grid" style="font-size:1.8rem; color:var(--dash-accent); line-height:1;"></i>
                            <div>
                                <h5 style="margin:0 0 5px; color:var(--dash-primary); font-weight:700;">Diseñador de Cuestionarios</h5>
                                <p style="margin:0; font-size:0.9rem; color:var(--dash-text-muted);">
                                    ¡Excelente elección! Una vez que <strong>guardes este tema</strong>, aparecerá en la lista anterior. 
                                    Haz clic en el botón <strong style="color:var(--dash-accent);"><i class="bi bi-ui-checks-grid"></i> Quiz</strong> 
                                    al lado de este tema para usar el Constructor de Cuestionarios o <strong>generarlo con Inteligencia Artificial ✨</strong>.
                                </p>
                            </div>
                        </div>
                    </div>
                }

                @* ============================================================ *@
                @* SECCIÓN: Material de Apoyo (archivos adjuntos 1-3)           *@
                @* Solo visible cuando el tema ya fue guardado (tiene ID)        *@
                @* ============================================================ *@
                @if (editingTopicId.HasValue)
                {
                    <hr style="border-color:var(--dash-border); margin:20px 0;"/>
                    <div class="dash-form-group">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
                            <label class="dash-form-label" style="margin:0;">
                                <i class="bi bi-paperclip" style="color:var(--dash-accent);"></i>
                                Material de Apoyo
                                <span style="font-weight:400; font-size:0.8rem; color:var(--dash-text-muted); margin-left:6px;">(imágenes, PDF, Word)</span>
                            </label>
                            <span class="topic-file-counter @(archivosTema.Count >= 3 ? "at-limit" : "")">
                                <i class="bi bi-files"></i> @archivosTema.Count / 3
                            </span>
                        </div>

                        @* Zona de subida *@
                        @* Fix Blazor Server: InputFile con display:none + label for evita el bug _blazorFilesById *@
                        <InputFile id="topic-file-input" OnChange="OnTopicFileSelected"
                                   accept=".jpg,.jpeg,.png,.webp,.gif,.pdf,.doc,.docx"
                                   style="display:none;" />

                        @if (archivosTema.Count < 3)
                        {
                            <label for="topic-file-input" class="topic-upload-zone @(uploadingFile ? "uploading" : "")"
                                   style="cursor: @(uploadingFile ? "wait" : "pointer"); display:block;">
                                @if (uploadingFile)
                                {
                                    <div class="upload-progress-anim">
                                        <div class="dash-spinner" style="width:32px;height:32px;"></div>
                                        <span style="color:var(--dash-text-muted); font-size:0.9rem;">Subiendo archivo...</span>
                                    </div>
                                }
                                else
                                {
                                    <i class="bi bi-cloud-upload" style="font-size:2.2rem; color:var(--dash-accent); display:block; margin-bottom:8px;"></i>
                                    <p style="margin:0 0 6px; font-weight:600; color:var(--dash-text);">Arrastra un archivo o haz clic aquí</p>
                                    <p style="margin:0; font-size:0.8rem; color:var(--dash-text-muted);">JPG, PNG, PDF, DOCX · Máx. 3 MB · @(3 - archivosTema.Count) lugar(es) disponible(s)</p>
                                }
                            </label>
                        }
                        else
                        {
                            <div style="text-align:center; padding:12px; background:rgba(var(--color-warning-rgb,255,193,7),0.08); border:1px dashed rgba(255,193,7,0.5); border-radius:10px; color:var(--dash-text-muted); font-size:0.9rem;">
                                <i class="bi bi-exclamation-triangle" style="color:#ffc107;"></i> Límite alcanzado (3/3). Elimina un archivo para agregar otro.
                            </div>
                        }

                        @* Error de subida *@
                        @if (!string.IsNullOrEmpty(uploadError))
                        {
                            <div style="margin-top:10px; padding:8px 12px; background:rgba(220,53,69,0.08); border-left:3px solid #dc3545; border-radius:6px; font-size:0.85rem; color:#dc3545;">
                                <i class="bi bi-exclamation-circle"></i> @uploadError
                            </div>
                        }

                        @* Lista de archivos ya subidos *@
                        @if (archivosTema.Any())
                        {
                            <div style="margin-top:14px; display:flex; flex-direction:column; gap:8px;">
                                @foreach (var archivo in archivosTema)
                                {
                                    <div class="topic-file-item">
                                        <div style="display:flex; align-items:center; gap:12px; flex:1; min-width:0;">
                                            <div class="topic-file-icon @GetFileIconClass(archivo.TipoArchivo)">
                                                <i class="bi @GetFileIcon(archivo.TipoArchivo)"></i>
                                            </div>
                                            <div style="min-width:0; flex:1;">
                                                <div style="font-weight:600; font-size:0.9rem; color:var(--dash-text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@archivo.NombreOriginal">
                                                    @archivo.NombreOriginal
                                                </div>
                                                <div style="font-size:0.75rem; color:var(--dash-text-muted);">
                                                    <span class="topic-file-badge @GetFileIconClass(archivo.TipoArchivo)">@archivo.TipoArchivo.ToUpper()</span>
                                                    <span style="margin-left:6px;">@FormatBytes(archivo.TamanoBytes)</span>
                                                </div>
                                            </div>
                                        </div>
                                        <button class="dash-btn dash-btn-danger dash-btn-sm" @onclick="() => EliminarArchivoTema(archivo.Id)" title="Eliminar archivo" style="flex-shrink:0;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="margin-top:16px; padding:12px 16px; background:rgba(var(--color-primary-rgb),0.05); border:1px dashed var(--dash-border); border-radius:10px; font-size:0.85rem; color:var(--dash-text-muted); text-align:center;">
                        <i class="bi bi-info-circle" style="color:var(--dash-accent);"></i> Guarda el tema primero para adjuntar archivos de apoyo.
                    </div>
                }
            </div>
            <div class="dash-modal-footer">
                <button class="dash-btn dash-btn-outline" @onclick="() => showTopicModal = false">Cancelar</button>
                <button class="dash-btn dash-btn-primary" @onclick="SaveTopic" disabled="@saving">
                    @if (saving) { <span>Guardando...</span> }
                    else { <span><i class="bi bi-check-lg"></i> @(isEditing ? "Actualizar Tema" : "Crear Tema")</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid CourseId { get; set; }

    private List<Lesson> lessons = new();
    private HashSet<Guid> expandedLessons = new();
    
    private bool loading = true, showModal = false, showTopicModal = false, saving = false, isEditing = false;
    private bool shouldInitQuill = false;
    private string alertMessage = "", alertClass = "", alertIcon = "";
    
    private CreateLessonRequest currentLesson = new();
    private Guid? editingLessonId;

    private CreateTemaRequest currentTopic = new();
    private Guid? editingTopicId;
    private Guid currentModifyingLessonId;

    // --- Archivos de apoyo del tema ---
    private List<ArchivoTema> archivosTema = new();
    private bool uploadingFile = false;
    private string uploadError = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLessons();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldInitQuill && showTopicModal)
        {
            shouldInitQuill = false;
            await Task.Delay(300); // Give time for DOM to render the modal
            await JSRuntime.InvokeVoidAsync("quillInterop.init", "quill-editor", "Escribe el contenido aquí...");
            if (!string.IsNullOrEmpty(currentTopic.TextContent))
            {
                await JSRuntime.InvokeVoidAsync("quillInterop.setContent", "quill-editor", currentTopic.TextContent);
            }
        }
    }

    private async Task LoadLessons()
    {
        loading = true;
        try 
        { 
            lessons = await MaestroService.GetLeccionesCursoAsync(CourseId); 
            // Si la lista de Temas en la DB de Lesson viene nula (por no incluir MultiMapping dapper), inicializamos a vacía
            foreach(var l in lessons) {
                if (l.Topics == null) l.Topics = new List<Tema>();
            }
            // Optional: If you want to automatically load topics for ALL lessons upfront, uncomment next lines:
            // foreach(var l in lessons) {
            //    l.Topics = await MaestroService.GetTemasLeccionAsync(l.Id);
            // }
            // But doing it lazily on Accordion click is faster.
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
        finally { loading = false; }
    }

    // --- ACCORDION LOGIC ---
    private async Task ToggleLessonAccordion(Guid lessonId)
    {
        if (expandedLessons.Contains(lessonId))
        {
            expandedLessons.Remove(lessonId);
        }
        else
        {
            expandedLessons.Add(lessonId);
            var lesson = lessons.FirstOrDefault(l => l.Id == lessonId);
            if (lesson != null && (lesson.Topics == null || !lesson.Topics.Any())) 
            {
                // Load topics dynamically upon expand
                lesson.Topics = await MaestroService.GetTemasLeccionAsync(lessonId);
            }
        }
    }

    // --- MODAL LECCION (MODULOS) ---
    private void OpenCreateModal()
    {
        isEditing = false;
        editingLessonId = null;
        currentLesson = new CreateLessonRequest
        {
            CourseId = CourseId,
            Order = lessons.Any() ? lessons.Max(l => l.Order) + 1 : 1
        };
        showModal = true;
    }

    private void OpenEditModal(Lesson lesson)
    {
        isEditing = true;
        editingLessonId = lesson.Id;
        currentLesson = new CreateLessonRequest
        {
            CourseId = CourseId,
            Title = lesson.Title,
            Description = lesson.Description,
            Order = lesson.Order
        };
        showModal = true;
    }

    private async Task SaveLesson()
    {
        if (string.IsNullOrWhiteSpace(currentLesson.Title))
        { ShowAlert("El título es obligatorio", "warning"); return; }

        saving = true;
        try
        {
            if (isEditing && editingLessonId.HasValue)
            {
                var result = await MaestroService.ActualizarLeccionAsync(editingLessonId.Value, currentLesson);
                ShowAlert(result.Success ? "Módulo actualizado" : result.Message, result.Success ? "success" : "danger");
            }
            else
            {
                var userId = AuthService.CurrentUser?.Id ?? Guid.Empty;
                var result = await MaestroService.CrearLeccionAsync(userId, currentLesson);
                ShowAlert(result.Success ? "Módulo creado" : result.Message, result.Success ? "success" : "danger");
            }
            showModal = false;
            await LoadLessons();
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
        finally { saving = false; }
    }

    private async Task DeleteLesson(Guid lessonId)
    {
        try
        {
            var result = await MaestroService.EliminarLeccionAsync(lessonId);
            ShowAlert(result.Success ? "Módulo eliminado" : result.Message, result.Success ? "success" : "danger");
            await LoadLessons();
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
    }

    // --- MODAL TOPICS (TEMAS) ---
    private void OpenTopicCreateModal(Guid lessonId)
    {
        var lesson = lessons.FirstOrDefault(l => l.Id == lessonId);
        isEditing = false;
        editingTopicId = null;
        currentModifyingLessonId = lessonId;
        archivosTema = new();
        uploadError = "";
        currentTopic = new CreateTemaRequest
        {
            LessonId = lessonId,
            ContentType = ContentType.Lectura,
            Order = (lesson?.Topics?.Any() == true) ? lesson.Topics.Max(t => t.Order) + 1 : 1
        };
        showTopicModal = true;
        shouldInitQuill = true;
    }

    private async Task OpenTopicEditModal(Tema topic, Guid lessonId)
    {
        isEditing = true;
        editingTopicId = topic.Id;
        currentModifyingLessonId = lessonId;
        uploadError = "";
        currentTopic = new CreateTemaRequest
        {
            LessonId = lessonId,
            Title = topic.Title,
            Description = topic.Description,
            ContentType = topic.ContentType,
            TextContent = topic.TextContent,
            ContentUrl = topic.ContentUrl,
            DurationMinutes = topic.DurationMinutes,
            Order = topic.Order,
            IsFree = topic.IsFree
        };
        showTopicModal = true;
        shouldInitQuill = true;
        // Cargar archivos existentes
        archivosTema = await MaestroService.GetArchivosTemaAsync(topic.Id);
        // Fix URLs for display (the service does this already, but ensure it)
    }

    private async Task SaveTopic()
    {
        // Get content from Quill before saving
        if (currentTopic.ContentType == ContentType.Lectura || currentTopic.ContentType == ContentType.VideoExterno || currentTopic.ContentType == ContentType.VideoSubido)
        {
            currentTopic.TextContent = await JSRuntime.InvokeAsync<string>("quillInterop.getContent", "quill-editor");
        }

        if (string.IsNullOrWhiteSpace(currentTopic.Title))
        { ShowAlert("El título del tema es obligatorio", "warning"); return; }

        saving = true;
        try
        {
            if (isEditing && editingTopicId.HasValue)
            {
                var result = await MaestroService.ActualizarTemaAsync(editingTopicId.Value, currentTopic);
                ShowAlert(result.Success ? "Tema actualizado" : result.Message, result.Success ? "success" : "danger");
            }
            else
            {
                var result = await MaestroService.CrearTemaAsync(currentModifyingLessonId, currentTopic);
                ShowAlert(result.Success ? "Tema creado" : result.Message, result.Success ? "success" : "danger");
            }
            showTopicModal = false;
            
            // Reload just the topics for this lesson
            var lessonToUpdate = lessons.FirstOrDefault(l => l.Id == currentModifyingLessonId);
            if (lessonToUpdate != null) {
                lessonToUpdate.Topics = await MaestroService.GetTemasLeccionAsync(currentModifyingLessonId);
            }
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
        finally { saving = false; }
    }

    private async Task DeleteTopic(Guid topicId, Guid lessonId)
    {
        try
        {
            var result = await MaestroService.EliminarTemaAsync(topicId);
            ShowAlert(result.Success ? "Tema eliminado" : result.Message, result.Success ? "success" : "danger");
            
            var lessonToUpdate = lessons.FirstOrDefault(l => l.Id == lessonId);
            if (lessonToUpdate != null) {
                lessonToUpdate.Topics = await MaestroService.GetTemasLeccionAsync(lessonId);
            }
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
    }

    // --- ARCHIVOS DE APOYO ---
    private async Task OnTopicFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = "";
        if (!editingTopicId.HasValue) return;

        var file = e.File;
        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".webp", ".gif", ".pdf", ".doc", ".docx" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!allowedExtensions.Contains(extension))
        { uploadError = "Tipo de archivo no permitido. Use: JPG, PNG, PDF, DOC, DOCX"; return; }

        if (file.Size > 3 * 1024 * 1024)
        { uploadError = "El archivo supera el límite de 3 MB"; return; }

        if (archivosTema.Count >= 3)
        { uploadError = "Ya tienes 3 archivos adjuntos (límite máximo)"; return; }

        uploadingFile = true;
        StateHasChanged();
        try
        {
            // Determine MIME type
            var mimeType = extension switch
            {
                ".pdf" => "application/pdf",
                ".doc" => "application/msword",
                ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                ".png" => "image/png",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "image/jpeg"
            };

            using var stream = file.OpenReadStream(maxAllowedSize: 3 * 1024 * 1024);
            var archivo = await MaestroService.SubirArchivoTemaAsync(editingTopicId.Value, stream, file.Name, mimeType);

            if (archivo != null)
            {
                archivosTema.Add(archivo);
                uploadError = "";
            }
            else
            {
                uploadError = "No se pudo subir el archivo. Verifica el límite de 3 archivos o intenta de nuevo.";
            }
        }
        catch (Exception ex)
        {
            uploadError = $"Error: {ex.Message}";
        }
        finally
        {
            uploadingFile = false;
        }
    }

    private async Task EliminarArchivoTema(Guid archivoId)
    {
        var ok = await MaestroService.EliminarArchivoTemaAsync(archivoId);
        if (ok)
            archivosTema.RemoveAll(a => a.Id == archivoId);
        else
            uploadError = "No se pudo eliminar el archivo.";
    }

