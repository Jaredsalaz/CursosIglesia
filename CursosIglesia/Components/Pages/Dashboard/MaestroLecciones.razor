        _ => "bi-file-earmark-fill"
    };

    private string GetFileIconClass(string tipo) => tipo.ToLower() switch
    {
        "pdf" => "file-pdf",
        "doc" or "docx" => "file-word",
        "png" or "jpg" or "jpeg" or "webp" or "gif" => "file-image",
        _ => "file-other"
    };

    private string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertClass = $"dash-alert-{type}";
        alertIcon = type == "success" ? "bi-check-circle" : type == "danger" ? "bi-exclamation-circle" : "bi-exclamation-triangle";
    }

