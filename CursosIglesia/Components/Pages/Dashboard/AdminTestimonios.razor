@page "/dashboard/admin/testimonios"
@layout CursosIglesia.Components.Layout.DashboardLayout
@inject ITestimonialService TestimonialService
@inject IJSRuntime JS
@using CursosIglesia.Models

<div class="dash-header mb-4">
    <h2 class="dash-title">Moderación de Testimonios</h2>
    <p class="text-muted">Revisa y aprueba las reseñas enviadas por los alumnos.</p>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="dash-alert @alertClass">
        <i class="bi @alertIcon"></i> @alertMessage
    </div>
}

<div class="dash-panel">
    <div class="dash-panel-body" style="padding:0;">
        @if (loading)
        {
            <div class="dash-loading"><div class="dash-spinner"></div></div>
        }
        else if (pendingTestimonials.Any())
        {
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Alumno</th>
                        <th>Curso</th>
                        <th>Calificación</th>
                        <th>Comentario</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in pendingTestimonials)
                    {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <img src="@t.StudentImageUrl" style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover;" />
                                    <div style="font-weight:600; font-size:0.9rem;">@t.StudentName</div>
                                </div>
                            </td>
                            <td><span class="dash-badge dash-badge-info">@t.CourseName</span></td>
                            <td>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= t.Rating ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <div style="max-width: 300px; font-size: 0.85rem; color: var(--dash-text-muted); font-style: italic;">
                                    "@t.Comment"
                                </div>
                            </td>
                            <td style="font-size: 0.8rem;">@t.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <button class="dash-btn dash-btn-primary dash-btn-sm" @onclick="() => Approve(t.Id)" disabled="@processingIds.Contains(t.Id)">
                                    @if (processingIds.Contains(t.Id))
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg"></i> <span>Aprobar</span>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="dash-empty">
                <i class="bi bi-chat-heart"></i>
                <h4>No hay testimonios pendientes</h4>
                <p>¡Buen trabajo! Has moderado todas las reseñas.</p>
            </div>
        }
    </div>
</div>

@code {
    private List<Testimonial> pendingTestimonials = new();
    private bool loading = true;
    private HashSet<Guid> processingIds = new();
    private string alertMessage = "", alertClass = "", alertIcon = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            pendingTestimonials = await TestimonialService.GetPendingTestimonialsAsync();
        }
        catch (Exception ex)
        {
            ShowAlert($"Error al cargar: {ex.Message}", "danger");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Approve(Guid id)
    {
        processingIds.Add(id);
        try
        {
            var success = await TestimonialService.ApproveTestimonialAsync(id);
            if (success)
            {
                ShowAlert("Testimonio aprobado correctamente.", "success");
                await LoadData();
            }
            else
            {
                ShowAlert("No se pudo aprobar el testimonio.", "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Error: {ex.Message}", "danger");
        }
        finally
        {
            processingIds.Remove(id);
        }
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertClass = $"dash-alert-{type}";
        alertIcon = type == "success" ? "bi-check-circle" : "bi-exclamation-circle";
        
        _ = Task.Run(async () => 
        {
            await Task.Delay(4000);
            alertMessage = "";
            await InvokeAsync(StateHasChanged);
        });
    }
}
