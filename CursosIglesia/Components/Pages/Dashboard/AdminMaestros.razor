@page "/dashboard/admin/maestros"
@layout CursosIglesia.Components.Layout.DashboardLayout
@inject IAdminService AdminService
@using CursosIglesia.Models.DTOs

<!-- Actions Bar -->
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    <div class="dash-search" style="flex:1; max-width:400px; margin-bottom:0;">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar maestro..." @bind="searchTerm" @bind:event="oninput" />
    </div>
    <button class="dash-btn dash-btn-primary" @onclick="() => showModal = true">
        <i class="bi bi-plus-lg"></i> Nuevo Maestro
    </button>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="dash-alert @alertClass">
        <i class="bi @alertIcon"></i> @alertMessage
    </div>
}

<!-- Maestros Table -->
<div class="dash-panel">
    <div class="dash-panel-body" style="padding:0;">
        @if (loading)
        {
            <div class="dash-loading"><div class="dash-spinner"></div></div>
        }
        else if (filteredMaestros.Any())
        {
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Maestro</th>
                        <th>Especialidad</th>
                        <th>Experiencia</th>
                        <th>Cursos</th>
                        <th>Alumnos</th>
                        <th>Estado</th>
                        <th>Registrado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in filteredMaestros)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div class="sidebar-user-avatar" style="width:34px; height:34px; font-size:0.75rem;">
                                        @(m.Nombre.Length > 0 ? m.Nombre[0].ToString() : "?")@(m.Apellidos.Length > 0 ? m.Apellidos[0].ToString() : "")
                                    </div>
                                    <div>
                                        <div style="font-weight:600;">@m.NombreCompleto</div>
                                        <div style="font-size:0.75rem; color:var(--dash-text-muted);">@m.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="dash-badge dash-badge-gold">@m.Especialidad</span></td>
                            <td>@m.ExperienciaAnios años</td>
                            <td><strong>@m.TotalCursos</strong></td>
                            <td><strong>@m.TotalAlumnos</strong></td>
                            <td>
                                @if (m.Activo)
                                {
                                    <span class="dash-badge dash-badge-success"><i class="bi bi-check-circle"></i> Activo</span>
                                }
                                else
                                {
                                    <span class="dash-badge dash-badge-danger"><i class="bi bi-x-circle"></i> Inactivo</span>
                                }
                            </td>
                            <td style="font-size:0.82rem; color:var(--dash-text-muted)">@m.FechaRegistro?.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="dash-empty">
                <i class="bi bi-people"></i>
                <h4>No se encontraron maestros</h4>
                <p>Crea un nuevo maestro con el botón superior</p>
            </div>
        }
    </div>
</div>

<!-- Create Maestro Modal -->
@if (showModal)
{
    <div class="dash-modal-backdrop" @onclick="CloseModal">
        <div class="dash-modal" @onclick:stopPropagation="true">
            <div class="dash-modal-header">
                <span class="dash-modal-title"><i class="bi bi-person-plus" style="color:var(--dash-accent)"></i> Crear Nuevo Maestro</span>
                <button class="dash-modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="dash-modal-body">
                <div class="dash-form-row">
                    <div class="dash-form-group">
                        <label class="dash-form-label">Nombre *</label>
                        <input class="dash-form-input" @bind="newMaestro.Nombre" placeholder="Nombre" />
                    </div>
                    <div class="dash-form-group">
                        <label class="dash-form-label">Apellidos *</label>
                        <input class="dash-form-input" @bind="newMaestro.Apellidos" placeholder="Apellidos" />
                    </div>
                </div>
                <div class="dash-form-group">
                    <label class="dash-form-label">Correo Electrónico *</label>
                    <input class="dash-form-input" type="email" @bind="newMaestro.Email" placeholder="correo@ejemplo.com" />
                </div>
                <div class="dash-form-group">
                    <label class="dash-form-label">Contraseña *</label>
                    <input class="dash-form-input" type="password" @bind="newMaestro.Password" placeholder="Contraseña inicial" />
                </div>
                <div class="dash-form-row">
                    <div class="dash-form-group">
                        <label class="dash-form-label">Teléfono</label>
                        <input class="dash-form-input" @bind="newMaestro.Telefono" placeholder="+52..." />
                    </div>
                    <div class="dash-form-group">
                        <label class="dash-form-label">Años de Experiencia</label>
                        <input class="dash-form-input" type="number" @bind="newMaestro.ExperienciaAnios" />
                    </div>
                </div>
                <div class="dash-form-group">
                    <label class="dash-form-label">Especialidad *</label>
                    <input class="dash-form-input" @bind="newMaestro.Especialidad" placeholder="Ej: Teología, Catequesis, Biblia..." />
                </div>
            </div>
            <div class="dash-modal-footer">
                <button class="dash-btn dash-btn-outline" @onclick="CloseModal">Cancelar</button>
                <button class="dash-btn dash-btn-primary" @onclick="CreateMaestro" disabled="@saving">
                    @if (saving) { <span>Creando...</span> } else { <span><i class="bi bi-check-lg"></i> Crear Maestro</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<MaestroDetail> maestros = new();
    private bool loading = true;
    private bool showModal = false;
    private bool saving = false;
    private string searchTerm = "";
    private string alertMessage = "";
    private string alertClass = "";
    private string alertIcon = "";
    private CreateMaestroRequest newMaestro = new();

    private IEnumerable<MaestroDetail> filteredMaestros => string.IsNullOrWhiteSpace(searchTerm) 
        ? maestros 
        : maestros.Where(m => m.NombreCompleto.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) 
            || m.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || m.Especialidad.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadMaestros();
    }

    private async Task LoadMaestros()
    {
        loading = true;
        try { maestros = await AdminService.GetAllMaestrosAsync(); }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
        finally { loading = false; }
    }

    private async Task CreateMaestro()
    {
        if (string.IsNullOrWhiteSpace(newMaestro.Nombre) || string.IsNullOrWhiteSpace(newMaestro.Email) || string.IsNullOrWhiteSpace(newMaestro.Password))
        {
            ShowAlert("Nombre, email y contraseña son obligatorios", "warning");
            return;
        }

        saving = true;
        try
        {
            var result = await AdminService.CrearMaestroAsync(newMaestro);
            if (result.Success)
            {
                ShowAlert("Maestro creado exitosamente", "success");
                CloseModal();
                await LoadMaestros();
            }
            else
            {
                ShowAlert(result.Message, "danger");
            }
        }
        catch (Exception ex) { ShowAlert($"Error: {ex.Message}", "danger"); }
        finally { saving = false; }
    }

    private void CloseModal()
    {
        showModal = false;
        newMaestro = new();
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertClass = $"dash-alert-{type}";
        alertIcon = type == "success" ? "bi-check-circle" : type == "danger" ? "bi-exclamation-circle" : "bi-exclamation-triangle";
    }
}
