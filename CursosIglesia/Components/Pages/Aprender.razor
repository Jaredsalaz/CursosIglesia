@page "/aprender/{CourseId:int}"
@rendermode InteractiveServer
@inject LearningViewModel ViewModel
@inject NavigationManager Navigation

<PageTitle>@(ViewModel.Course?.Title ?? "Aprendiendo") - Cursos Católicos</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="loading-container" style="min-height:100vh">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando curso...</p>
    </div>
}
else if (ViewModel.ErrorMessage != null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle" style="font-size:4rem; color:var(--color-secondary)"></i>
        <h3 class="mt-3">@ViewModel.ErrorMessage</h3>
        <div class="d-flex gap-2 justify-content-center mt-3">
            <a href="/cursos" class="btn-catholic">
                <i class="bi bi-arrow-left"></i> Ver Cursos
            </a>
            <a href="/mis-cursos" class="btn-gold">
                <i class="bi bi-journal-bookmark"></i> Mis Cursos
            </a>
        </div>
    </div>
}
else if (ViewModel.Course != null)
{
    <div class="learning-layout">
        <!-- Sidebar -->
        <aside class="learning-sidebar @(ViewModel.IsSidebarOpen ? "open" : "collapsed")">
            <div class="sidebar-header">
                <div class="sidebar-course-info">
                    <h4>@ViewModel.Course.Title</h4>
                    <div class="sidebar-progress-info">
                        <span>@ViewModel.CompletedCount / @ViewModel.TotalLessons lecciones</span>
                        <span class="fw-bold">@ViewModel.Progress%</span>
                    </div>
                    <div class="progress-bar-track">
                        <div class="progress-bar-fill @(ViewModel.Enrollment?.IsCompleted == true ? "completed" : "")"
                             style="width: @ViewModel.Progress%"></div>
                    </div>
                </div>
                <button class="sidebar-toggle" @onclick="ViewModel.ToggleSidebar">
                    <i class="bi @(ViewModel.IsSidebarOpen ? "bi-chevron-left" : "bi-chevron-right")"></i>
                </button>
            </div>

            <nav class="lesson-nav">
                @foreach (var lesson in ViewModel.Course.Lessons.OrderBy(l => l.Order))
                {
                    var isCompleted = ViewModel.IsLessonCompleted(lesson.Id);
                    var isCurrent = ViewModel.CurrentLesson?.Id == lesson.Id;

                    <button class="lesson-nav-item @(isCurrent ? "active" : "") @(isCompleted ? "completed" : "")"
                            @onclick="() => SelectLesson(lesson.Id)">
                        <div class="lesson-nav-status">
                            @if (isCompleted)
                            {
                                <i class="bi bi-check-circle-fill"></i>
                            }
                            else if (isCurrent)
                            {
                                <i class="bi bi-play-circle-fill"></i>
                            }
                            else
                            {
                                <span class="lesson-nav-number">@lesson.Order</span>
                            }
                        </div>
                        <div class="lesson-nav-info">
                            <div class="lesson-nav-title">@lesson.Title</div>
                            <div class="lesson-nav-meta">
                                <i class="bi @GetLessonIcon(lesson.Type)"></i>
                                @lesson.Type · @lesson.DurationMinutes min
                            </div>
                        </div>
                    </button>
                }
            </nav>

            <div class="sidebar-footer">
                <a href="/curso/@ViewModel.Course.Id" class="sidebar-back-link">
                    <i class="bi bi-arrow-left me-1"></i> Detalle del Curso
                </a>
                <a href="/mis-cursos" class="sidebar-back-link">
                    <i class="bi bi-journal-bookmark me-1"></i> Mis Cursos
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="learning-content">
            <!-- Top Bar -->
            <div class="learning-topbar">
                <button class="sidebar-toggle-mobile" @onclick="ViewModel.ToggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-breadcrumb">
                    <a href="/">Inicio</a>
                    <i class="bi bi-chevron-right"></i>
                    <a href="/mis-cursos">Mis Cursos</a>
                    <i class="bi bi-chevron-right"></i>
                    <span>@ViewModel.Course.Title</span>
                </div>
                <div class="topbar-progress">
                    <span>@ViewModel.Progress% completado</span>
                </div>
            </div>

            @if (ViewModel.CurrentLesson != null)
            {
                var lesson = ViewModel.CurrentLesson;

                <!-- Lesson Content -->
                <div class="lesson-content-area">
                    <!-- Lesson Header -->
                    <div class="lesson-header">
                        <div class="lesson-header-meta">
                            <span class="lesson-type-badge">
                                <i class="bi @GetLessonIcon(lesson.Type) me-1"></i>@lesson.Type
                            </span>
                            <span class="lesson-duration">
                                <i class="bi bi-clock me-1"></i>@lesson.DurationMinutes minutos
                            </span>
                            <span class="lesson-order">
                                Lección @lesson.Order de @ViewModel.TotalLessons
                            </span>
                        </div>
                        <h2>@lesson.Title</h2>
                        <p class="lesson-description">@lesson.Description</p>
                    </div>

                    <!-- Lesson Body (Content Placeholder) -->
                    <div class="lesson-body">
                        @switch (lesson.Type)
                        {
                            case LessonType.Video:
                                <div class="lesson-placeholder video-placeholder">
                                    <div class="placeholder-icon">
                                        <i class="bi bi-play-circle"></i>
                                    </div>
                                    <h4>Contenido de Video</h4>
                                    <p>Aquí se mostrará el video de la lección "@lesson.Title"</p>
                                    <div class="placeholder-meta">
                                        <i class="bi bi-clock me-1"></i> Duración: @lesson.DurationMinutes minutos
                                    </div>
                                </div>
                                break;

                            case LessonType.Lectura:
                                <div class="lesson-placeholder reading-placeholder">
                                    <div class="placeholder-icon">
                                        <i class="bi bi-book"></i>
                                    </div>
                                    <h4>Material de Lectura</h4>
                                    <p>Aquí se mostrará el contenido de lectura para "@lesson.Title"</p>
                                    <div class="placeholder-meta">
                                        <i class="bi bi-clock me-1"></i> Tiempo estimado: @lesson.DurationMinutes minutos
                                    </div>
                                </div>
                                break;

                            case LessonType.Cuestionario:
                                <div class="lesson-placeholder quiz-placeholder">
                                    <div class="placeholder-icon">
                                        <i class="bi bi-question-circle"></i>
                                    </div>
                                    <h4>Cuestionario</h4>
                                    <p>Aquí se mostrará el cuestionario de evaluación para "@lesson.Title"</p>
                                    <div class="placeholder-meta">
                                        <i class="bi bi-clock me-1"></i> Tiempo estimado: @lesson.DurationMinutes minutos
                                    </div>
                                </div>
                                break;

                            case LessonType.Actividad:
                                <div class="lesson-placeholder activity-placeholder">
                                    <div class="placeholder-icon">
                                        <i class="bi bi-pencil-square"></i>
                                    </div>
                                    <h4>Actividad Práctica</h4>
                                    <p>Aquí se mostrará la actividad práctica para "@lesson.Title"</p>
                                    <div class="placeholder-meta">
                                        <i class="bi bi-clock me-1"></i> Tiempo estimado: @lesson.DurationMinutes minutos
                                    </div>
                                </div>
                                break;
                        }
                    </div>

                    <!-- Lesson Actions -->
                    <div class="lesson-actions">
                        @if (ViewModel.IsCurrentLessonCompleted)
                        {
                            <div class="lesson-completed-badge">
                                <i class="bi bi-check-circle-fill me-2"></i> Lección completada
                            </div>
                        }

                        <div class="lesson-action-buttons">
                            @{
                                var prevLesson = ViewModel.Course.Lessons
                                    .Where(l => l.Order < lesson.Order)
                                    .OrderByDescending(l => l.Order)
                                    .FirstOrDefault();

                                var nextLesson = ViewModel.Course.Lessons
                                    .Where(l => l.Order > lesson.Order)
                                    .OrderBy(l => l.Order)
                                    .FirstOrDefault();
                            }

                            @if (prevLesson != null)
                            {
                                <button class="btn-lesson-nav prev" @onclick="() => SelectLesson(prevLesson.Id)">
                                    <i class="bi bi-chevron-left me-1"></i> Anterior
                                </button>
                            }

                            @if (!ViewModel.IsCurrentLessonCompleted)
                            {
                                @if (nextLesson != null)
                                {
                                    <button class="btn-catholic" @onclick="CompleteAndNext">
                                        Completar y Siguiente <i class="bi bi-chevron-right ms-1"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-catholic" @onclick="CompleteLesson">
                                        <i class="bi bi-check-circle me-1"></i> Completar Curso
                                    </button>
                                }
                            }
                            else if (nextLesson != null)
                            {
                                <button class="btn-catholic" @onclick="() => SelectLesson(nextLesson.Id)">
                                    Siguiente <i class="bi bi-chevron-right ms-1"></i>
                                </button>
                            }
                            else if (ViewModel.Enrollment?.IsCompleted == true)
                            {
                                <div class="course-completed-message">
                                    <i class="bi bi-trophy-fill me-2"></i>
                                    <span>¡Felicidades! Has completado el curso.</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </main>
    </div>
}

@code {
    [Parameter]
    public int CourseId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await ViewModel.LoadCourseAsync(CourseId);
    }

    private async Task SelectLesson(int lessonId)
    {
        await ViewModel.SelectLessonAsync(lessonId);
    }

    private async Task CompleteAndNext()
    {
        await ViewModel.CompleteAndNextAsync();
    }

    private async Task CompleteLesson()
    {
        await ViewModel.CompleteCurrentLessonAsync();
    }

    private string GetLessonIcon(LessonType type) => type switch
    {
        LessonType.Video => "bi-play-circle",
        LessonType.Lectura => "bi-book",
        LessonType.Cuestionario => "bi-question-circle",
        LessonType.Actividad => "bi-pencil-square",
        _ => "bi-file-text"
    };
}
