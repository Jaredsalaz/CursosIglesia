@page "/aprender/{CourseId:guid}"
@using Microsoft.AspNetCore.Authorization
@using System
@using System.Web
@using System.ComponentModel
@using CursosIglesia.Models
@implements IDisposable
@attribute [Authorize]
@inject LearningViewModel ViewModel
@inject NavigationManager Navigation
@inject IMaestroService MaestroService

<PageTitle>@(ViewModel.Course?.Title ?? "Aprendiendo") - Cursos Católicos</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="loading-container" style="min-height:100vh">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando curso...</p>
    </div>
}
else if (ViewModel.ErrorMessage != null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle" style="font-size:4rem; color:var(--color-secondary)"></i>
        <h3 class="mt-3">@ViewModel.ErrorMessage</h3>
        <div class="d-flex gap-2 justify-content-center mt-3">
            <a href="/cursos" class="btn-catholic">
                <i class="bi bi-arrow-left"></i> Ver Cursos
            </a>
            <a href="/mis-cursos" class="btn-gold">
                <i class="bi bi-journal-bookmark"></i> Mis Cursos
            </a>
        </div>
    </div>
}
else if (ViewModel.Course != null)
{
    <div class="learning-layout">
        <!-- Sidebar -->
        <aside class="learning-sidebar @(ViewModel.IsSidebarOpen ? "open" : "collapsed")">
            <div class="sidebar-header">
                <div class="sidebar-course-info">
                    <h4>@ViewModel.Course.Title</h4>
                    <div class="sidebar-progress-info">
                        <span>@ViewModel.CompletedCount / @ViewModel.TotalTopics temas</span>
                        <span class="fw-bold">@Math.Round(ViewModel.Progress)%</span>
                    </div>
                    <div class="progress-bar-track">
                        <div class="progress-bar-fill @(ViewModel.Progress >= 100 ? "completed" : "")"
                             style="width: @Math.Round(ViewModel.Progress)%"></div>
                    </div>
                </div>
                <button class="sidebar-toggle" @onclick="ViewModel.ToggleSidebar">
                    <i class="bi @(ViewModel.IsSidebarOpen ? "bi-chevron-left" : "bi-chevron-right")"></i>
                </button>
            </div>

            <nav class="lesson-nav">
                @foreach (var lesson in ViewModel.Course.Lessons.OrderBy(l => l.Order))
                {
                    var isCompleted = ViewModel.IsLessonCompleted(lesson.Id);
                    var isCurrent = ViewModel.CurrentLesson?.Id == lesson.Id;
                    var isLessonLocked = ViewModel.IsLessonLocked(lesson.Id);
                    var isLessonDone = ViewModel.IsLessonCompleted(lesson.Id);

                    <div class="lesson-nav-group @(isCurrent ? "active" : "")">
                        <button class="lesson-nav-item @(isCurrent ? "active" : "") @(isLessonDone ? "completed" : "") @(isLessonLocked ? "locked" : "")"
                                @onclick="() => !isLessonLocked ? SelectLesson(lesson.Id) : Task.CompletedTask"
                                disabled="@isLessonLocked">
                            <div class="lesson-nav-status">
                                @if (isLessonLocked)
                                {
                                    <i class="bi bi-lock-fill"></i>
                                }
                                else if (isLessonDone)
                                {
                                    <i class="bi bi-check-circle-fill"></i>
                                }
                                else if (isCurrent)
                                {
                                    <i class="bi bi-play-circle-fill"></i>
                                }
                                else
                                {
                                    <span class="lesson-nav-number">@lesson.Order</span>
                                }
                            </div>
                            <div class="lesson-nav-info">
                                <div class="lesson-nav-title">@lesson.Title</div>
                                <div class="lesson-nav-meta">
                                    <i class="bi bi-stack"></i>
                                    @(lesson.Topics?.Count ?? 0) temas
                                </div>
                            </div>
                        </button>

                        @if (isCurrent && lesson.Topics != null && lesson.Topics.Any())
                        {
                            <div class="topic-nav-list">
                                @foreach (var topic in lesson.Topics.OrderBy(t => t.Order))
                                {
                                    var isCurrentTopic = ViewModel.CurrentTopic?.Id == topic.Id;
                                    var isTopicLocked = ViewModel.IsTopicLocked(topic.Id);
                                    var isTopicDone = ViewModel.IsTopicCompleted(topic.Id);

                                    <button class="topic-nav-item @(isCurrentTopic ? "active" : "") @(isTopicLocked ? "locked" : "")" 
                                            @onclick="() => !isTopicLocked ? ViewModel.SelectTopicAsync(topic) : Task.CompletedTask"
                                            disabled="@isTopicLocked">
                                        <i class="bi @(isTopicLocked ? "bi-lock" : (isTopicDone ? "bi-check-circle-fill text-success" : GetTopicIcon(topic.ContentType))) me-2"></i>
                                        <span>@topic.Title</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </nav>

            <div class="sidebar-footer">
                <a href="/curso/@ViewModel.Course.Id" class="sidebar-back-link">
                    <i class="bi bi-arrow-left me-1"></i> Detalle del Curso
                </a>
                <a href="/mis-cursos" class="sidebar-back-link">
                    <i class="bi bi-journal-bookmark me-1"></i> Mis Cursos
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="learning-content">
            <!-- Top Bar -->
            <div class="learning-topbar">
                <button class="sidebar-toggle-mobile" @onclick="ViewModel.ToggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-breadcrumb">
                    <a href="/">Inicio</a>
                    <i class="bi bi-chevron-right"></i>
                    <a href="/mis-cursos">Mis Cursos</a>
                    <i class="bi bi-chevron-right"></i>
                    <span>@ViewModel.Course.Title</span>
                </div>
                <div class="topbar-progress">
                    <span>@Math.Round(ViewModel.Progress)% completado</span>
                </div>
            </div>

            @if (ViewModel.CurrentLesson != null)
            {
                var lesson = ViewModel.CurrentLesson;

                <!-- Lesson Content -->
                <div class="lesson-content-area">
                    <!-- Lesson Header -->
                    <div class="lesson-header">
                        <div class="lesson-header-meta">
                            <span class="lesson-type-badge">
                                <i class="bi bi-stack me-1"></i> Módulo
                            </span>
                            <span class="lesson-duration">
                                <i class="bi bi-list-check me-1"></i>@(lesson.Topics?.Count ?? 0) temas
                            </span>
                            <span class="lesson-order">
                                Lección @lesson.Order de @ViewModel.TotalTopics
                            </span>
                        </div>
                        <h2>@lesson.Title</h2>
                        <p class="lesson-description">@lesson.Description</p>
                    </div>

                    <!-- Lesson Body (Content) -->
                    <div class="lesson-body">
                        @if (ViewModel.CurrentTopic != null)
                        {
                            var topic = ViewModel.CurrentTopic;
                            <div class="topic-content @topic.ContentType.ToString().ToLower()">
                                <h3 class="topic-title">@topic.Title</h3>
                                
                                @if (topic.ContentType == ContentType.Lectura)
                                {
                                    <div class="topic-text-content">
                                        @((MarkupString)topic.TextContent)
                                    </div>
                                }
                                else if (topic.ContentType == ContentType.VideoExterno || topic.ContentType == ContentType.VideoSubido)
                                {
                                    <div class="topic-video-container">
                                        @if (!string.IsNullOrEmpty(topic.ContentUrl))
                                        {
                                            @if (topic.ContentUrl.Contains("youtube.com") || topic.ContentUrl.Contains("youtu.be"))
                                            {
                                                var videoId = ExtractYoutubeId(topic.ContentUrl);
                                                <iframe width="100%" height="500" src="https://www.youtube.com/embed/@videoId" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                                            }
                                            else
                                            {
                                                <video width="100%" controls>
                                                    <source src="@topic.ContentUrl" type="video/mp4">
                                                    Tu navegador no soporta el elemento de video.
                                                </video>
                                            }
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning">No hay URL de video configurada.</div>
                                        }
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(topic.TextContent))
                                    {
                                        <div class="topic-text-content mt-4">
                                            @((MarkupString)topic.TextContent)
                                        </div>
                                    }
                                }
                                else if (topic.ContentType == ContentType.Test)
                                {
                                    <div class="topic-quiz-container mt-4">
                                        <StudentQuiz TemaId="@topic.Id" />
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(topic.TextContent) && !topic.TextContent.TrimStart().StartsWith("["))
                                    {
                                        <div class="topic-text-content mt-4">
                                            @((MarkupString)topic.TextContent)
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="topic-generic-content">
                                        <p>Este tema es de tipo @topic.ContentType. </p>
                                        @if (!string.IsNullOrEmpty(topic.ContentUrl))
                                        {
                                            <a href="@topic.ContentUrl" target="_blank" class="btn btn-primary">Ver contenido externo</a>
                                        }
                                    </div>
                                }

                                @* --- Material de Apoyo: archivos descargables --- *@
                                @if (archivosTema.Any())
                                {
                                    <div class="apoyo-files-section">
                                        <div class="apoyo-files-title">
                                            <i class="bi bi-paperclip" style="color:var(--color-primary);"></i>
                                            Material de Apoyo
                                        </div>
                                        @foreach (var archivo in archivosTema)
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" download="@archivo.NombreOriginal" class="apoyo-file-link">
                                                <span style="width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; @GetApoyoIconStyle(archivo.TipoArchivo)">
                                                    <i class="bi @GetApoyoIcon(archivo.TipoArchivo)"></i>
                                                </span>
                                                <div style="flex:1; min-width:0;">
                                                    <div style="font-weight:600; font-size:0.9rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@archivo.NombreOriginal</div>
                                                    <div style="font-size:0.75rem; opacity:0.6;">@archivo.TipoArchivo.ToUpper() &middot; @FormatApoyoBytes(archivo.TamanoBytes)</div>
                                                </div>
                                                <i class="bi bi-download" style="font-size:1rem; opacity:0.5; flex-shrink:0;"></i>
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else if (lesson.Topics == null || !lesson.Topics.Any())
                        {
                            <div class="lesson-placeholder reading-placeholder">
                                <div class="placeholder-icon">
                                    <i class="bi bi-journal-x"></i>
                                </div>
                                <h4>Módulo de contenido</h4>
                                <p>El instructor está preparando el material para esta sección.</p>
                            </div>
                        }
                        else
                        {
                            <div class="topics-list">
                                <h4 class="mb-3">Temas en este módulo:</h4>
                                @foreach (var topic in lesson.Topics.OrderBy(t => t.Order))
                                {
                                    var itLocked = ViewModel.IsTopicLocked(topic.Id);
                                    var topicStyle = $"margin-bottom: 1rem; border-left: 4px solid {(itLocked ? "#ccc" : "var(--color-primary)")}; opacity: {(itLocked ? "0.6" : "1")}; text-align:left; display:flex; gap:1.5rem; justify-content:flex-start; align-items:flex-start;";
                                    var iconColor = itLocked ? "#999" : "var(--color-primary)";

                                    <div class="lesson-placeholder @(itLocked ? "locked" : "")" style="@topicStyle">
                                        <div class="placeholder-icon" style="font-size:2rem; margin:0; color:@iconColor">
                                            <i class="bi @(itLocked ? "bi-lock-fill" : GetTopicIcon(topic.ContentType))"></i>
                                        </div>
                                        <div style="flex:1;">
                                            <h4 style="margin-bottom:0.5rem; font-size:1.1rem">@topic.Title</h4>
                                            @if (!string.IsNullOrEmpty(topic.Description))
                                            {
                                                <p style="margin-bottom:0.8rem; font-size:0.9rem; color:var(--color-text-muted)">@topic.Description</p>
                                            }
                                            <div class="placeholder-meta" style="justify-content:flex-start; font-size:0.85rem;">
                                                <i class="bi bi-clock me-1"></i> @topic.DurationMinutes min
                                                @if (ViewModel.IsTopicCompleted(topic.Id))
                                                {
                                                    <span class="ms-2 text-success"><i class="bi bi-check-circle-fill"></i> Completado</span>
                                                }
                                            </div>
                                        </div>
                                        <button class="btn-catholic" @onclick="() => !itLocked ? ViewModel.SelectTopicAsync(topic) : Task.CompletedTask" 
                                                style="padding:0.5rem 1rem; font-size:0.9rem" disabled="@itLocked">
                                            @(itLocked ? "Bloqueado" : "Entrar") <i class="bi @(itLocked ? "bi-lock" : "bi-arrow-right") ms-1"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Lesson Actions -->
                    <div class="lesson-actions">
                        @if (ViewModel.IsCurrentLessonCompleted)
                        {
                            <div class="lesson-completed-badge">
                                <i class="bi bi-check-circle-fill me-2"></i> Tema completado
                            </div>
                        }

                        <div class="lesson-action-buttons">
                            @if (!ViewModel.IsCurrentLessonCompleted)
                            {
                                @if (ViewModel.CurrentTopic?.ContentType != ContentType.Test)
                                {
                                    <button class="btn-catholic" @onclick="CompleteAndNext">
                                        Completar y Siguiente <i class="bi bi-chevron-right ms-1"></i>
                                    </button>
                                }
                                else 
                                {
                                    <div class="text-muted small">
                                        <i class="bi bi-info-circle me-1"></i> Pasa el test para continuar
                                    </div>
                                }
                            }
                            else 
                            {
                                <button class="btn-catholic" @onclick="CompleteAndNext">
                                    Siguiente <i class="bi bi-chevron-right ms-1"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </main>
    </div>
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    private bool _isInitialized = false;
    private List<ArchivoTema> archivosTema = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isInitialized && CourseId != Guid.Empty)
        {
            _isInitialized = true;
            ViewModel.PropertyChanged += OnViewModelPropertyChanged;
            await ViewModel.LoadCourseAsync(CourseId);
            // Load attachments for the first topic selected
            if (ViewModel.CurrentTopic != null)
                await LoadArchivosTema(ViewModel.CurrentTopic.Id);
            StateHasChanged();
        }
    }

    private Guid _lastLoadedTopicId = Guid.Empty;

    private void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        // Reload topic files whenever the selected topic changes
        if (e.PropertyName == nameof(ViewModel.CurrentTopic) || e.PropertyName == null)
        {
            var topicId = ViewModel.CurrentTopic?.Id ?? Guid.Empty;
            if (topicId != Guid.Empty && topicId != _lastLoadedTopicId)
            {
                _lastLoadedTopicId = topicId;
                InvokeAsync(async () =>
                {
                    await LoadArchivosTema(topicId);
                    StateHasChanged();
                });
                return;
            }
        }
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ViewModel.CurrentTopic != null && 
            ViewModel.CurrentTopic.ContentType != ContentType.Test && 
            !ViewModel.IsTopicCompleted(ViewModel.CurrentTopic.Id))
        {
            await ViewModel.CompleteCurrentTopicAsync();
        }
    }

    private async Task SelectLesson(Guid lessonId)
    {
        await ViewModel.SelectLessonAsync(lessonId);
        StateHasChanged();
    }

    private async Task CompleteAndNext()
    {
        await ViewModel.CompleteAndNextAsync();
    }

    // Load files when a topic is selected
    private async Task LoadArchivosTema(Guid temaId)
    {
        try { archivosTema = await MaestroService.GetArchivosTemaAsync(temaId); }
        catch { archivosTema = new(); }
    }

    private string GetTopicIcon(ContentType type) => type switch
    {
        ContentType.VideoSubido => "bi-play-circle",
        ContentType.VideoExterno => "bi-youtube",
        ContentType.Lectura => "bi-book",
        ContentType.Test => "bi-card-checklist",
        ContentType.Archivo => "bi-file-earmark-pdf",
        ContentType.ClaseVirtual => "bi-camera-video",
        _ => "bi-file-text"
    };

    private string GetApoyoIcon(string tipo) => tipo.ToLower() switch
    {
        "pdf" => "bi-file-earmark-pdf-fill",
        "doc" or "docx" => "bi-file-earmark-word-fill",
        "png" or "jpg" or "jpeg" or "webp" or "gif" => "bi-file-earmark-image-fill",
        _ => "bi-file-earmark-fill"
    };

    private string GetApoyoIconStyle(string tipo) => tipo.ToLower() switch
    {
        "pdf" => "background:rgba(239,68,68,0.12); color:#ef4444;",
        "doc" or "docx" => "background:rgba(59,130,246,0.12); color:#3b82f6;",
        "png" or "jpg" or "jpeg" or "webp" or "gif" => "background:rgba(168,85,247,0.12); color:#a855f7;",
        _ => "background:rgba(156,163,175,0.12); color:#9ca3af;"
    };

    private string FormatApoyoBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private string ExtractYoutubeId(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        try {
            if (url.Contains("youtu.be/")) {
                return url.Split('/').Last().Split('?').First();
            }
            var uri = new Uri(url);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            return query["v"] ?? url.Split('/').Last();
        } catch {
            return "";
        }
    }
}

<style>
    /* Progression Styles */
    .lesson-nav-item.locked, .topic-nav-item.locked, .lesson-placeholder.locked {
        opacity: 0.5;
        cursor: not-allowed !important;
    }
    .lesson-nav-item.locked button, .topic-nav-item.locked, .lesson-placeholder.locked button {
        pointer-events: none;
    }
    .topic-nav-item.active {
        background: rgba(13, 110, 253, 0.1);
        border-right: 3px solid #0d6efd;
        font-weight: 600;
    }
</style>
