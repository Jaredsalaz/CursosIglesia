@page "/verify/{CertificateNumber}"
@using System.Net.Http.Json
@inject HttpClient Http
@inject ILogger<Verify> Logger

<div class="verify-container">
    <div class="verify-card">
        <div class="verify-header">
            <i class="fas fa-certificate"></i>
            <h1>Verificar Certificado</h1>
        </div>

        @if (IsLoading)
        {
            <div class="text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Verificando...</span>
                </div>
                <p>Verificando certificado...</p>
            </div>
        }
        else if (CertificateFound)
        {
            <div class="verify-result success">
                <div class="result-icon">✅</div>
                <h2>Certificado Válido</h2>

                <div class="cert-details">
                    <div class="detail-row">
                        <span class="label">Estudiante:</span>
                        <span class="value">@VerifiedCertificate?.NombreEstudiante</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Curso:</span>
                        <span class="value">@VerifiedCertificate?.NombreCurso</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Emitido:</span>
                        <span class="value">@VerifiedCertificate?.FechaOtorgamiento.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Número de Certificado:</span>
                        <span class="value"><code>@CertificateNumber</code></span>
                    </div>
                </div>

                <div class="seal">
                    <i class="fas fa-award"></i>
                </div>
            </div>
        }
        else
        {
            <div class="verify-result error">
                <div class="result-icon">❌</div>
                <h2>Certificado No Válido</h2>
                <p>No se encontró un certificado con este número.</p>
                <p class="certificate-number">Número: <code>@CertificateNumber</code></p>
            </div>
        }

        <div class="verify-footer">
            <p class="footer-text">
                Esta página verifica la autenticidad de certificados emitidos por la Plataforma de Formación Católica
            </p>
            <a href="/" class="btn btn-primary">Volver al Inicio</a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? CertificateNumber { get; set; }

    private bool IsLoading = true;
    private bool CertificateFound = false;
    private dynamic? VerifiedCertificate;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(CertificateNumber))
        {
            IsLoading = false;
            return;
        }

        try
        {
            // Llamar al endpoint de verificación
            var result = await Http.GetFromJsonAsync<dynamic>($"api/certificates/verify/{CertificateNumber}");

            if (result != null)
            {
                VerifiedCertificate = result;
                CertificateFound = result.Valido == true || (result.Valido is int and 1);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error verificando certificado: {ex.Message}");
            CertificateFound = false;
        }
        finally
        {
            IsLoading = false;
        }
    }
}

<style>
    .verify-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #fefaf3 0%, #e8dcc8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .verify-card {
        background: white;
        border: 3px solid #D4AF37;
        border-radius: 16px;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .verify-header {
        background: linear-gradient(135deg, #704D14 0%, #8B6F47 100%);
        color: white;
        padding: 2rem;
        text-align: center;
    }

    .verify-header i {
        font-size: 3rem;
        margin-bottom: 1rem;
        display: block;
    }

    .verify-header h1 {
        font-size: 1.8rem;
        margin: 0;
    }

    .verify-result {
        padding: 2rem;
        text-align: center;
    }

    .result-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .verify-result h2 {
        color: #1a3a52;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
    }

    .verify-result.success {
        background: #f0fdf4;
    }

    .verify-result.error {
        background: #fef2f2;
    }

    .cert-details {
        background: #fefaf3;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        text-align: left;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e0d5c7;
    }

    .detail-row:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .detail-row .label {
        font-weight: bold;
        color: #704D14;
    }

    .detail-row .value {
        color: #333;
    }

    .detail-row code {
        background: #f0f0f0;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
    }

    .certificate-number {
        margin-top: 1rem;
    }

    .certificate-number code {
        background: #f0f0f0;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
    }

    .seal {
        font-size: 5rem;
        color: #D4AF37;
        margin: 1rem 0;
        opacity: 0.3;
    }

    .verify-footer {
        background: #f8f9fa;
        padding: 2rem;
        text-align: center;
        border-top: 1px solid #e0e0e0;
    }

    .footer-text {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .btn {
        padding: 0.75rem 2rem;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-primary {
        background-color: #704D14;
        color: white;
        border: none;
    }

    .btn-primary:hover {
        background-color: #8B6F47;
    }
</style>
