@page "/curso/{CourseId:guid}"
@inject CourseDetailViewModel ViewModel

<PageTitle>@(ViewModel.Course?.Title ?? "Curso") - Cursos Católicos</PageTitle>

@if (ViewModel.IsLoading)
{
    <div class="loading-container" style="min-height:500px">
        <div class="loading-spinner"></div>
        <p class="mt-3 text-muted">Cargando curso...</p>
    </div>
}
else if (ViewModel.Course is null)
{
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle" style="font-size:4rem; color:var(--color-secondary)"></i>
        <h3 class="mt-3">Curso no encontrado</h3>
        <p class="text-muted">El curso que buscas no existe o ha sido removido.</p>
        <a href="/cursos" class="btn-catholic">
            <i class="bi bi-arrow-left"></i> Volver a Cursos
        </a>
    </div>
}
else
{
    var course = ViewModel.Course;

    <!-- Course Hero -->
    <section class="course-detail-hero">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Inicio</a></li>
                    <li class="breadcrumb-item"><a href="/cursos">Cursos</a></li>
                    <li class="breadcrumb-item active">@course.CategoryName</li>
                </ol>
            </nav>
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="d-flex gap-2 mb-3">
                        <span class="badge-difficulty badge-@course.Difficulty.ToString().ToLower()">
                            @course.Difficulty
                        </span>
                        @if (course.IsFree)
                        {
                            <span style="background:linear-gradient(135deg,#28a745,#20c997);color:#fff;padding:4px 12px;border-radius:20px;font-size:0.75rem;font-weight:600">GRATIS</span>
                        }
                        @if (course.IsFeatured)
                        {
                            <span style="background:var(--gradient-gold);color:#fff;padding:4px 12px;border-radius:20px;font-size:0.75rem;font-weight:600"><i class="bi bi-star-fill me-1"></i>DESTACADO</span>
                        }
                    </div>
                    <h1>@course.Title</h1>
                    <p style="font-size:1.1rem;color:rgba(255,255,255,0.85)">@course.ShortDescription</p>

                    <div class="course-meta-detail">
                        <div class="meta-item">
                            <i class="bi bi-person-circle"></i>
                            <span>@course.Instructor</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-star-fill"></i>
                            <span>@course.Rating.ToString("0.0") (@course.RatingsCount valoraciones)</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-people-fill"></i>
                            <span>@course.StudentsEnrolled.ToString("N0") estudiantes</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-clock"></i>
                            <span>@course.DurationHours horas</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-journal-text"></i>
                            <span>@course.LessonsCount lecciones</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Course Content -->
    <section class="section" style="padding-top:2rem">
        <div class="container">
            <div class="row g-4">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <!-- Description -->
                    <div class="mb-4">
                        <h3 style="font-size:1.4rem">Acerca de este Curso</h3>
                        <div class="decorative-divider" style="justify-content:flex-start;margin-left:0">
                            <i class="bi bi-cross"></i>
                        </div>
                        <p style="line-height:1.8;color:var(--color-text-light)">@course.Description</p>
                    </div>

                    <!-- Topics -->
                    <div class="mb-4">
                        <h3 style="font-size:1.4rem">Temas que Aprenderás</h3>
                        <div class="decorative-divider" style="justify-content:flex-start;margin-left:0">
                            <i class="bi bi-cross"></i>
                        </div>
                        <div class="row g-2">
                            @foreach (var topic in course.Topics)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center gap-2 p-2" style="background:var(--color-bg);border-radius:var(--radius-sm)">
                                        <i class="bi bi-check-circle-fill" style="color:var(--color-secondary)"></i>
                                        <span style="font-size:0.9rem">@topic</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Lessons -->
                    <div class="mb-4">
                        <h3 style="font-size:1.4rem">
                            Contenido del Curso
                            <span class="text-muted" style="font-size:0.85rem;font-family:var(--font-body)">(@course.LessonsCount lecciones)</span>
                        </h3>
                        <div class="decorative-divider" style="justify-content:flex-start;margin-left:0">
                            <i class="bi bi-cross"></i>
                        </div>

                        @foreach (var lesson in ViewModel.VisibleLessons)
                        {
                            <div class="lesson-item">
                                <div class="lesson-number">@lesson.Order</div>
                                <div class="lesson-info">
                                    <div class="lesson-title">@lesson.Title</div>
                                    @if (!string.IsNullOrEmpty(lesson.Description))
                                    {
                                        <div class="mt-1 mb-2" style="font-size:0.85rem;color:var(--color-text-muted)">@lesson.Description</div>
                                    }
                                    
                                    @if (lesson.Topics != null && lesson.Topics.Any())
                                    {
                                        <div class="ps-3 border-start mt-2">
                                            @foreach (var topic in lesson.Topics.OrderBy(t => t.Order))
                                            {
                                                <div class="lesson-meta mb-2">
                                                    <span style="color:var(--color-text); font-weight:500;">
                                                        <i class="bi @GetTopicIcon(topic.ContentType) me-1" style="color:var(--color-secondary)"></i>
                                                        @topic.Title
                                                    </span>
                                                    <span><i class="bi bi-clock me-1"></i>@topic.DurationMinutes min</span>
                                                    @if (topic.IsFree)
                                                    {
                                                        <span class="lesson-badge">Vista previa</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (course.Lessons.Count > 5)
                        {
                            <div class="text-center mt-3">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="ViewModel.ToggleLessons">
                                    @if (ViewModel.ShowAllLessons)
                                    {
                                        <span><i class="bi bi-chevron-up me-1"></i>Mostrar menos</span>
                                    }
                                    else
                                    {
                                        <span><i class="bi bi-chevron-down me-1"></i>Ver todas las @course.LessonsCount lecciones</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>

                    <!-- Instructor -->
                    <div class="mb-4">
                        <h3 style="font-size:1.4rem">Tu Instructor</h3>
                        <div class="decorative-divider" style="justify-content:flex-start;margin-left:0">
                            <i class="bi bi-cross"></i>
                        </div>
                        <div class="d-flex gap-3 align-items-start p-3" style="background:var(--color-bg);border-radius:var(--radius-md)">
                            <img src="@course.InstructorImageUrl" alt="@course.Instructor"
                                 style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--color-secondary)" />
                            <div>
                                <h5 class="mb-1" style="font-size:1.1rem">@course.Instructor</h5>
                                <p class="mb-0 small text-muted">@course.InstructorBio</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <div class="course-sidebar">
                        <img src="@course.ImageUrl" alt="@course.Title" class="sidebar-image" />
                        <div class="sidebar-body">
                            <div class="price-tag @(course.IsFree ? "free" : "")">
                                @(course.IsFree ? "Gratis" : $"${course.Price:0.00} USD")
                            </div>
                            @if (ViewModel.IsEnrolled)
                            {
                                <a href="/aprender/@course.Id" class="btn-catholic w-100 justify-content-center mb-3" style="padding:0.85rem">
                                    <i class="bi bi-play-fill"></i> Continuar Curso
                                </a>
                                <div class="text-center mb-3">
                                    <span class="badge bg-success-subtle text-success p-2 w-100 border border-success-subtle">
                                        <i class="bi bi-check-circle-fill me-1"></i> Ya estás inscrito
                                    </span>
                                </div>
                            }
                            else
                            {
                                <button class="btn-catholic w-100 justify-content-center mb-3" style="padding:0.85rem"
                                        @onclick="Enroll" disabled="@ViewModel.IsEnrolling">
                                    @if (ViewModel.IsEnrolling)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                        <span>Inscribiendo...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-play-circle"></i>
                                        @(course.IsFree ? "Inscribirse Gratis" : "Comprar Curso")
                                    }
                                </button>
                            }
                            <hr />
                            <ul class="list-unstyled mb-0">
                                <li class="d-flex justify-content-between py-2 border-bottom" style="font-size:0.9rem">
                                    <span class="text-muted"><i class="bi bi-clock me-2"></i>Duración</span>
                                    <strong>@course.DurationHours horas</strong>
                                </li>
                                <li class="d-flex justify-content-between py-2 border-bottom" style="font-size:0.9rem">
                                    <span class="text-muted"><i class="bi bi-journal-text me-2"></i>Lecciones</span>
                                    <strong>@course.LessonsCount</strong>
                                </li>
                                <li class="d-flex justify-content-between py-2 border-bottom" style="font-size:0.9rem">
                                    <span class="text-muted"><i class="bi bi-bar-chart me-2"></i>Nivel</span>
                                    <strong>@course.Difficulty</strong>
                                </li>
                                <li class="d-flex justify-content-between py-2 border-bottom" style="font-size:0.9rem">
                                    <span class="text-muted"><i class="bi bi-people me-2"></i>Estudiantes</span>
                                    <strong>@course.StudentsEnrolled.ToString("N0")</strong>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Testimonials Section -->
            <div class="mt-5 pt-4 border-top">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h3 style="font-size:1.4rem">Lo que dicen los alumnos</h3>
                                <div class="decorative-divider" style="justify-content:flex-start;margin-left:0;margin-bottom:0">
                                    <i class="bi bi-cross"></i>
                                </div>
                            </div>
                            @if (ViewModel.IsEnrolled && !ViewModel.IsSubmittingTestimonial)
                            {
                                <button class="btn btn-catholic-sm" type="button" data-bs-toggle="collapse" data-bs-target="#reviewForm">
                                    <i class="bi bi-pencil-square me-1"></i> Escribir reseña
                                </button>
                            }
                        </div>

                        <!-- Add Review Form -->
                        @if (ViewModel.IsEnrolled)
                        {
                            <div class="collapse mb-4" id="reviewForm">
                                <div class="card card-body border-0 shadow-sm bg-light" style="border-radius: var(--radius-md)">
                                    <h5 class="mb-3">Tu opinión es importante</h5>
                                    
                                    <div class="mb-3">
                                        <label class="form-label d-block text-muted small">Calificación</label>
                                        <div class="star-rating-input">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                var starValue = i;
                                                <i class="bi @(ViewModel.NewRating >= starValue ? "bi-star-fill text-warning" : "bi-star text-muted")"
                                                   style="cursor: pointer; font-size: 1.5rem;"
                                                   @onclick="() => ViewModel.NewRating = starValue"></i>
                                            }
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="reviewComment" class="form-label text-muted small">Comentario (mín. 10 caracteres)</label>
                                        <textarea class="form-control border-0" id="reviewComment" rows="3" 
                                                  placeholder="Cuéntanos tu experiencia con este curso..."
                                                  @bind="ViewModel.NewComment"></textarea>
                                    </div>

                                    <div class="text-end">
                                        <button class="btn btn-catholic-sm" @onclick="ViewModel.SubmitTestimonialAsync" disabled="@ViewModel.IsSubmittingTestimonial">
                                            @if (ViewModel.IsSubmittingTestimonial)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                                <span>Enviando...</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-send-fill me-1"></i> <span>Enviar Reseña</span>
                                            }
                                        </button>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(ViewModel.TestimonialSuccessMessage))
                            {
                                <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: var(--radius-sm)">
                                    <i class="bi bi-check-circle-fill me-2"></i> @ViewModel.TestimonialSuccessMessage
                                </div>
                            }
                        }

                        <!-- Testimonials List -->
                        @if (!ViewModel.Testimonials.Any())
                        {
                            <div class="text-center py-4 bg-light rounded" style="border: 2px dashed #dee2e6">
                                <p class="text-muted mb-0">Todavía no hay reseñas para este curso. ¡Sé el primero en calificar!</p>
                            </div>
                        }
                        else
                        {
                            <div class="testimonials-list d-flex flex-column gap-3">
                                @foreach (var review in ViewModel.Testimonials)
                                {
                                    <div class="testimonial-card p-3 shadow-sm" style="background:#fff; border-radius:var(--radius-md)">
                                        <div class="d-flex justify-content-between mb-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="@review.StudentImageUrl" alt="@review.StudentName" 
                                                     style="width:40px;height:40px;border-radius:50%;object-fit:cover" />
                                                <div>
                                                    <div class="fw-bold small">@review.StudentName</div>
                                                    <div class="text-muted" style="font-size:0.7rem">@review.Date.ToString("MMM dd, yyyy")</div>
                                                </div>
                                            </div>
                                            <div class="rating-stars small">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="bi @(i <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                                                }
                                            </div>
                                        </div>
                                        <p class="mb-0 small text-secondary" style="font-style:italic">"@review.Comment"</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Statistics Summary -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm p-4" style="border-radius:var(--radius-md); background: linear-gradient(135deg, #ffffff, #f8f9fa)">
                            <h5 class="mb-3" style="font-size:1.1rem">Calificación general</h5>
                            <div class="text-center mb-3">
                                <div style="font-size:3rem; font-weight:700; color:var(--color-primary); line-height:1">@course.Rating.ToString("0.0")</div>
                                <div class="rating-stars mb-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= Math.Round(course.Rating) ? "bi-star-fill text-warning" : (i - course.Rating < 0.8 ? "bi-star-half text-warning" : "bi-star text-muted"))" style="font-size:1.2rem"></i>
                                    }
                                </div>
                                <div class="text-muted small">Basado en @course.RatingsCount reseñas</div>
                            </div>
                            
                            <!-- Rating Bars Placeholder -->
                            <div class="rating-bars d-flex flex-column gap-2 mt-3">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="small text-muted" style="width:15px">@i</span>
                                        <div class="progress flex-grow-1" style="height:6px">
                                            <div class="progress-bar bg-warning" style="width: @(i == 5 ? "85%" : (i == 4 ? "10%" : "2%"))"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Related Courses -->
            @if (ViewModel.RelatedCourses.Any())
            {
                <div class="mt-5">
                    <h3 style="font-size:1.4rem">Cursos Relacionados</h3>
                    <div class="decorative-divider" style="justify-content:flex-start;margin-left:0">
                        <i class="bi bi-cross"></i>
                    </div>
                    <div class="row g-4 mt-2">
                        @foreach (var related in ViewModel.RelatedCourses)
                        {
                            <div class="col-md-4">
                                <CourseCard Course="related" />
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await ViewModel.LoadCourseAsync(CourseId);
    }

    private string GetTopicIcon(ContentType type) => type switch
    {
        ContentType.VideoSubido => "bi-play-circle",
        ContentType.VideoExterno => "bi-youtube",
        ContentType.Lectura => "bi-book",
        ContentType.Test => "bi-card-checklist",
        ContentType.Archivo => "bi-file-earmark-pdf",
        ContentType.ClaseVirtual => "bi-camera-video",
        _ => "bi-file-text"
    };

    private async Task Enroll()
    {
        await ViewModel.EnrollAsync();
    }
}
