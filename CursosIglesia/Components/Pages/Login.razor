@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject LoginViewModel ViewModel
@inject NavigationManager NavigationManager
@inject IAuthService AuthService

<PageTitle>Iniciar Sesión - Cursos Católicos</PageTitle>

<div class="auth-page">
    <div class="auth-container">
        <!-- Left Panel: Decorative -->
        <div class="auth-panel-left">
            <div class="auth-panel-overlay"></div>
            <div class="auth-panel-content">
                <div class="auth-brand">
                    <i class="bi bi-cross"></i>
                    <span>Cursos Católicos</span>
                </div>
                <h2>Profundiza en tu Fe</h2>
                <p>Accede a cursos de formación católica impartidos por expertos en teología, doctrina y espiritualidad.</p>
                <div class="auth-features">
                    <div class="auth-feature">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Más de 50 cursos disponibles</span>
                    </div>
                    <div class="auth-feature">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Instructores certificados</span>
                    </div>
                    <div class="auth-feature">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Aprende a tu propio ritmo</span>
                    </div>
                    <div class="auth-feature">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Comunidad de más de 2,000 fieles</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: Login Form -->
        <div class="auth-panel-right">
            <div class="auth-form-wrapper">
                <div class="auth-form-header">
                    <div class="auth-icon-circle">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h1>Bienvenido de vuelta</h1>
                    <p>Ingresa tus credenciales para continuar tu formación</p>
                </div>

                @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                {
                    <div class="auth-alert auth-alert-error">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@ViewModel.ErrorMessage</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(ViewModel.SuccessMessage))
                {
                    <div class="auth-alert auth-alert-success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@ViewModel.SuccessMessage</span>
                    </div>
                }

                <div class="auth-form">
                    <div class="auth-input-group">
                        <label for="email">Correo electrónico</label>
                        <div class="auth-input-wrapper">
                            <i class="bi bi-envelope"></i>
                            <input type="email" id="email" placeholder="tu@correo.com"
                                   @bind="ViewModel.LoginModel.Email"
                                   @bind:event="oninput"
                                   disabled="@ViewModel.IsSubmitting" />
                        </div>
                    </div>

                    <div class="auth-input-group">
                        <label for="password">Contraseña</label>
                        <div class="auth-input-wrapper">
                            <i class="bi bi-lock"></i>
                            <input type="@(ViewModel.ShowPassword ? "text" : "password")" id="password"
                                   placeholder="Tu contraseña"
                                   @bind="ViewModel.LoginModel.Password"
                                   @bind:event="oninput"
                                   disabled="@ViewModel.IsSubmitting" />
                            <button type="button" class="auth-toggle-password" @onclick="ViewModel.TogglePassword">
                                <i class="bi @(ViewModel.ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="auth-options">
                        <label class="auth-checkbox">
                            <input type="checkbox" @bind="ViewModel.LoginModel.RememberMe" />
                            <span class="checkmark"></span>
                            Recordarme
                        </label>
                        <a href="#" class="auth-link">¿Olvidaste tu contraseña?</a>
                    </div>

                    <button class="auth-submit-btn" @onclick="HandleLogin" disabled="@ViewModel.IsSubmitting">
                        @if (ViewModel.IsSubmitting)
                        {
                            <span class="auth-spinner"></span>
                            <span>Iniciando sesión...</span>
                        }
                        else
                        {
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span>Iniciar Sesión</span>
                        }
                    </button>

                    <div class="auth-divider">
                        <span>o continúa con</span>
                    </div>

                    <div class="auth-social-buttons">
                        <button class="auth-social-btn" disabled>
                            <i class="bi bi-google"></i>
                            Google
                        </button>
                        <button class="auth-social-btn" disabled>
                            <i class="bi bi-facebook"></i>
                            Facebook
                        </button>
                    </div>

                    <div class="auth-footer-text">
                        ¿No tienes cuenta?
                        <a href="/registro" class="auth-link-bold">Crear una cuenta</a>
                    </div>
                </div>

                <div class="auth-demo-hint">
                    <i class="bi bi-info-circle"></i>
                    <span>Usa tus credenciales de usuario registrado</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleLogin()
    {
        var success = await ViewModel.LoginAsync();
        StateHasChanged();

        if (success)
        {
            await Task.Delay(1200);
            NavigationManager.NavigateTo("/");
        }
    }
}
