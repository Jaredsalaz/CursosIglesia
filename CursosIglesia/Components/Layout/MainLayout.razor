@inherits LayoutComponentBase
@inject IAuthService AuthService

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-catholic">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="bi bi-cross brand-icon"></i>
            Cursos Católicos
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door me-1"></i> Inicio
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/cursos">
                        <i class="bi bi-mortarboard me-1"></i> Cursos
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/nosotros">
                        <i class="bi bi-info-circle me-1"></i> Nosotros
                    </NavLink>
                </li>
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item ms-lg-1">
                            <NavLink class="nav-link" href="/mis-cursos">
                                <i class="bi bi-journal-bookmark me-1"></i> Mis Cursos
                            </NavLink>
                        </li>
                        <li class="nav-item ms-lg-1">
                            <CursosIglesia.Components.Shared.ProfileDropdown />
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link" href="/login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar Sesión
                            </a>
                        </li>
                        <li class="nav-item ms-lg-1">
                            <a class="btn btn-catholic btn-sm" href="/registro">
                                <i class="bi bi-person-plus"></i> Registrarse
                            </a>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

<!-- Main Content -->
<main>
    @Body
</main>

<!-- Footer -->
<footer class="footer-catholic">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="footer-brand">
                    <i class="bi bi-cross brand-icon"></i>
                    Cursos Católicos
                </div>
                <p>Plataforma de formación católica en línea. Ofrecemos cursos de calidad para profundizar en la fe, la doctrina y la espiritualidad de la Iglesia Católica.</p>
            </div>
            <div class="col-lg-2 col-md-4 mb-4">
                <h5>Cursos</h5>
                <ul>
                    <li><a href="/cursos">Catecismo</a></li>
                    <li><a href="/cursos">Biblia</a></li>
                    <li><a href="/cursos">Sacramentos</a></li>
                    <li><a href="/cursos">Oración</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-md-4 mb-4">
                <h5>Recursos</h5>
                <ul>
                    <li><a href="/nosotros">Sobre Nosotros</a></li>
                    <li><a href="#">Blog</a></li>
                    <li><a href="#">Preguntas Frecuentes</a></li>
                    <li><a href="#">Contacto</a></li>
                </ul>
            </div>
            <div class="col-lg-4 col-md-4 mb-4">
                <h5>Contacto</h5>
                <ul>
                    <li><i class="bi bi-envelope me-2"></i>info@cursoscatolicos.org</li>
                    <li><i class="bi bi-telephone me-2"></i>+52 (55) 1234-5678</li>
                    <li><i class="bi bi-geo-alt me-2"></i>Tuxtla Gutiérrez, México</li>
                </ul>
                <div class="mt-3">
                    <a href="#" class="me-3" style="font-size:1.3rem; color:rgba(255,255,255,0.7)"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="me-3" style="font-size:1.3rem; color:rgba(255,255,255,0.7)"><i class="bi bi-youtube"></i></a>
                    <a href="#" class="me-3" style="font-size:1.3rem; color:rgba(255,255,255,0.7)"><i class="bi bi-instagram"></i></a>
                    <a href="#" style="font-size:1.3rem; color:rgba(255,255,255,0.7)"><i class="bi bi-twitter-x"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="mb-0">© @DateTime.Now.Year Cursos Católicos. Todos los derechos reservados. | <em>Ad Maiorem Dei Gloriam</em></p>
        </div>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
    }
}
